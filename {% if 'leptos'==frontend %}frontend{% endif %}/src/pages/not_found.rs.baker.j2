use leptos::prelude::*;

/// Full-page 404 Not Found error page.
///
/// Activate by setting the view signal to `View::NotFound`.
#[component]
pub fn NotFound() -> impl IntoView {
    view! {
        <div class="flex min-h-[70vh] flex-col items-center justify-center gap-4 text-center p-8">
            <span class="text-9xl font-bold text-gray-200 dark:text-gray-700 select-none">
                "404"
            </span>
            <h1 class="text-2xl font-semibold text-gray-800 dark:text-white">
                "Page Not Found"
            </h1>
            <p class="max-w-md text-gray-500 dark:text-gray-400">
                "The page you are looking for does not exist or has been moved."
            </p>
        </div>
    }
}
