use leptos::prelude::*;

/// Top-level page layout wrapper: header bar + main content slot.
#[component]
pub fn Layout(
    #[prop(into)] view_title: Signal<&'static str>,
    children: Children,
) -> impl IntoView {
    view! {
        <div class="flex flex-col min-h-full">
            // Top header bar
            <header class="sticky top-0 z-10 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 px-6 py-4 flex items-center justify-between shadow-sm">
                <h1 class="text-xl font-semibold text-gray-800 dark:text-white">
                    {move || view_title.get()}
                </h1>
                <span class="text-sm text-gray-500 dark:text-gray-400">
                    "{{ project_name }} Admin"
                </span>
            </header>
            // Page content
            <div class="flex-1 p-6">
                {children()}
            </div>
        </div>
    }
}
