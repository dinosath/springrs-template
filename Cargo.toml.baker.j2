[package]
name = "{{project_name}}"
version = "{{project_version}}"
edition = "{{project_edition}}"
license = "MIT"
publish = false

[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
panic = "abort"
strip = "symbols"
debug = false
incremental = false
overflow-checks = false

[workspace]
exclude = ["e2e"]
{{ 'members = ["migration"]' if add_migrations and orm == "seaorm" }}

{% if orm == "seaorm" -%}
[workspace.dependencies]
automod = "1.0"
{{ 'sea-orm-migration = { version = "2.0.0-rc.37", features = ["runtime-tokio-rustls", "sqlx-postgres"], default-features = false }' if add_migrations }}
tokio = { version = "1", features = ["full"] }
{% endif -%}

[dependencies]
{{ 'automod.workspace = true' if orm == "seaorm" else 'automod = "1.0"' }}
{% if backend == 'axum' -%}
{% include "rust/axum/dependencies.jinja" %}
{% elif backend == 'spring-rs' -%}
{% include "rust/springrs/dependencies.jinja" %}
{% endif -%}
anyhow = "1.0"
chrono = { version = "0.4", features = ["serde"] }
{{ 'migration = { path = "migration" }' if add_migrations and orm == "seaorm" }}
serde = "1.0"
serde_json = "1.0"
serde_with = "3.16"
{% if orm == 'seaorm' and database=='postgres' -%}
sea-orm = { version = "2.0.0-rc.37", features = ["sqlx-postgres","runtime-tokio-rustls","macros","with-chrono","with-json","with-uuid","schema-sync","entity-registry","rbac"], default-features = false }
{% endif -%}
{% if orm == 'diesel' and database=='postgres' -%}
diesel = { version = "2", features = ["postgres", "r2d2", "chrono", "64-column-tables"] }
pq-sys = { version = "0.7", features = ["bundled"] }
diesel-derive-enum = { version = "2", features = ["postgres"] }
{% endif -%}
{{ 'static-serve = "0.6"' if frontend != 'none' }}
{% if row_level_security -%}
axum-tenant = { version = "0.1", features = ["axum"{% if orm == 'seaorm' %}, "sea-orm-2"{% endif %}] }
{% endif -%}
{% if 'rest' in protocols -%}
tower-http = { version = "0.6", features = ["set-header"{% if security_level | default('standard') == 'hardened' %}, "limit", "cors"{% endif %}] }
validator = { version = "0.20", features = ["derive"] }
{% endif -%}
{% if 'grpc' in protocols -%}
tonic = "0.14"
tonic-prost = "0.14"
prost-types = "0.13"
{% endif %}
{{ 'tokio.workspace = true' if orm == "seaorm" else 'tokio = { version = "1", features = ["full"] }' }}
mimalloc = { version = "0.1.50", features = ["secure"] }
{% if authentication == 'jwt' and 'rest' in protocols -%}
webgates = { git = "https://github.com/emirror-de/webgates", branch = "nightly", features = ["authn", "codecs"] }
webgates-axum = { git = "https://github.com/emirror-de/webgates", branch = "nightly" }
webgates-repositories = { git = "https://github.com/emirror-de/webgates", branch = "nightly" }
{% endif -%}

[dev-dependencies]
axum-test = "20.0"
testcontainers = "0.27"
testcontainers-modules = { version = "0.15", features = ["postgres"] }
reqwest = { version = "0.13", features = ["json", "cookies"], default-features = false }
serial_test = "3"

{% if 'grpc' in protocols -%}
[build-dependencies]
tonic-prost-build = "0.14"
{% endif -%}