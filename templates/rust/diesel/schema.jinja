{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
diesel::table! {
    {% for name, property in entity.attributes | items | selectattr('1.enum') -%}
    {% if loop.first -%}
    use diesel::sql_types::*;
    {% endif -%}
    use super::super::{{ entity_name | snake_case }}::{{ name | pascal_case }}Mapping;
    {% if loop.last %}
    {% endif -%}
    {% endfor -%}
    {{ entity_name | table_case }} (id) {
        id -> Int4,
        created_at -> Timestamp,
        last_updated -> Timestamp,
        {% if macros.entity_has_rls(entity, row_level_security)|trim == 'true' -%}
        tenant_id -> Varchar,
        {% endif -%}
        {% for name, property in entity.attributes | items -%}
        {%- if property.type == 'relation' -%}
        {%- if macros.relation_is_many_to_one(property)=='true' or macros.relation_is_one_to_one(property)=='true' -%}
        {{ name | snake_case }}_id -> {% if not property.required %}Nullable<{% endif %}Int4{% if not property.required %}>{% endif %},
        {%- endif -%}
        {%- elif property.type == 'string' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Varchar{% if not property.required %}>{% endif %},
        {%- elif property.type == 'text' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Text{% if not property.required %}>{% endif %},
        {%- elif property.type == 'integer' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Int4{% if not property.required %}>{% endif %},
        {%- elif property.type == 'biginteger' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Int8{% if not property.required %}>{% endif %},
        {%- elif property.type == 'float' or property.type == 'decimal' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Float8{% if not property.required %}>{% endif %},
        {%- elif property.type == 'boolean' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Bool{% if not property.required %}>{% endif %},
        {%- elif property.type == 'datetime' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Timestamp{% if not property.required %}>{% endif %},
        {%- elif property.type == 'date' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Date{% if not property.required %}>{% endif %},
        {%- elif property.type == 'time' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Time{% if not property.required %}>{% endif %},
        {%- elif property.type == 'email' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Varchar{% if not property.required %}>{% endif %},
        {%- elif property.type == 'enumeration' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}{{ name | pascal_case }}Mapping{% if not property.required %}>{% endif %},
        {%- elif property.type == 'json' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Jsonb{% if not property.required %}>{% endif %},
        {%- elif property.type == 'uid' -%}
        {{ rust_types.rust_var(name, false) }} -> {% if not property.required %}Nullable<{% endif %}Uuid{% if not property.required %}>{% endif %},
        {%- endif -%}
        {% endfor %}
    }
}

{% endfor -%}

{% for relation in macros.get_m2m_relations(entities) | split(',') -%}
{% if relation | trim != '' -%}
{% set left = relation | split("_") | first -%}
{% set right = relation | split("_") | last -%}
diesel::table! {
    {{ relation | snake_case }} ({{ left | snake_case }}_id, {{ right | snake_case }}_id) {
        {{ left | snake_case }}_id -> Int4,
        {{ right | snake_case }}_id -> Int4,
    }
}

{% endif -%}
{% endfor -%}

{% set ns_join = namespace(seen=[]) -%}
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% for name, property in entity.attributes | items -%}
{% if macros.relation_is_many_to_one(property)=='true' or macros.relation_is_one_to_one(property)=='true' -%}
{%- set src = entity_name | table_case -%}
{%- set tgt = property.target | table_case -%}
{%- if src != tgt -%}
{%- set pair = [src, tgt] | sort | join(':') -%}
{%- if pair not in ns_join.seen -%}
{%- set ns_join.seen = ns_join.seen + [pair] -%}
diesel::joinable!({{ src }} -> {{ tgt }} ({{ name | snake_case }}_id));
{% endif -%}
{% endif -%}
{% endif -%}
{% endfor -%}
{% endfor -%}

diesel::allow_tables_to_appear_in_same_query!(
    {% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
    {{ entity_name | table_case }},
    {% endfor -%}
    {% for relation in macros.get_m2m_relations(entities) | split(',') -%}
    {% if relation | trim != '' -%}
    {{ relation | snake_case }},
    {% endif -%}
    {% endfor -%}
);
