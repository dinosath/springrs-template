    /// Helper: list all entities visible to a specific tenant.
    async fn list_as_tenant(i: &TestInfra, tenant: &str) -> Vec<serde_json::Value> {
        let mut req = i.server.get("/api/{{ rls_plural }}");
{% if authentication != 'none' -%}
        req = req.add_header("Authorization", format!("Bearer {}", i.auth_token));
{% endif -%}
        req = req.add_header("X-Tenant-Id", tenant);
        let resp = req.await;
        assert!(
            resp.status_code().is_success(),
            "list_as_tenant({}) failed: {} – {:?}",
            tenant, resp.status_code(), resp.text()
        );
        let body: serde_json::Value = resp.json();
        if let Some(arr) = body.as_array() {
            arr.clone()
        } else if let Some(arr) = body["data"].as_array() {
            arr.clone()
        } else {
            panic!("unexpected list response shape: {:?}", body);
        }
    }

