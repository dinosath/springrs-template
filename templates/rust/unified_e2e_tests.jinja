//! Unified E2E Integration Tests
//!
//! A single `TestServer` (+ Postgres container) is created once per process
//! via `OnceLock` and reused across every test function in that process.
//!
//! When executed with **`cargo nextest run`** (process-per-test), each test
//! gets its own isolated Postgres instance — no cross-test interference.
//!
//! When executed with **`cargo test`**, all tests share one Postgres.  The
//! nextest `.config/nextest.toml` defines a test group per entity so that
//! within an entity tests run serially while different entities run in parallel.

use axum_test::TestServer;
use serde_json::json;
use std::sync::OnceLock;
{% if database == 'postgres' -%}
use testcontainers::ContainerAsync;
{% if authentication == 'keycloak' -%}
use testcontainers::{GenericImage, ImageExt};
{% endif -%}
use testcontainers_modules::{postgres::Postgres, testcontainers::runners::AsyncRunner};
{% endif -%}
{% if authentication == 'keycloak' -%}
use std::collections::HashMap;
{% endif -%}
use {{ project_name | snake_case }}::create_app;

// ============================================================================
// Shared infrastructure — one copy per OS process
// ============================================================================

/// Dedicated Tokio runtime that outlives every test.  Using a standalone
/// runtime avoids the "Tokio 1.x context … being shutdown" errors that
/// occur when `#[tokio::test]` runtimes race to drop shared `OnceCell`s.
fn shared_runtime() -> &'static tokio::runtime::Runtime {
    static RT: OnceLock<tokio::runtime::Runtime> = OnceLock::new();
    RT.get_or_init(|| {
        tokio::runtime::Builder::new_multi_thread()
            .enable_all()
            .build()
            .expect("failed to create shared tokio runtime")
    })
}

/// Everything a test needs: server handle, auth token, and the Postgres
/// container reference (kept alive so Docker doesn't stop it).
struct TestInfra {
    server: TestServer,
{% if authentication == 'jwt' or authentication == 'keycloak' -%}
    auth_token: String,
{% endif -%}
{% if database == 'postgres' -%}
    _container: ContainerAsync<Postgres>,
{% endif -%}
{% if authentication == 'keycloak' -%}
    _keycloak: ContainerAsync<GenericImage>,
{% endif -%}
}

fn infra() -> &'static TestInfra {
    static INFRA: OnceLock<TestInfra> = OnceLock::new();
    INFRA.get_or_init(|| {
        shared_runtime().block_on(async {
{% if database == 'postgres' -%}
            let container = Postgres::default()
                .start()
                .await
                .expect("failed to start Postgres container");

            let db_port = container
                .get_host_port_ipv4(5432)
                .await
                .expect("failed to get Postgres port");

            let database_url = format!(
                "postgres://postgres:postgres@127.0.0.1:{}/postgres",
                db_port
            );
            std::env::set_var("DATABASE_URL", &database_url);
{% endif -%}
{% if authentication == 'keycloak' -%}
            let keycloak = GenericImage::new("quay.io/keycloak/keycloak", "latest")
                .with_env_var("KEYCLOAK_ADMIN", "admin")
                .with_env_var("KEYCLOAK_ADMIN_PASSWORD", "admin")
                .with_exposed_port(8080)
                .with_wait_for(testcontainers::core::WaitFor::message_on_stdout("Keycloak"))
                .start()
                .await
                .expect("failed to start Keycloak container");

            let kc_port = keycloak
                .get_host_port_ipv4(8080)
                .await
                .expect("failed to get Keycloak port");
            std::env::set_var("KEYCLOAK_URL", format!("http://127.0.0.1:{}", kc_port));
{% endif -%}

            let app = create_app().await.expect("failed to create app");
            let server = TestServer::new(app);

{% if authentication == 'jwt' -%}
            // Register + obtain a reusable JWT token.
            let reg_resp = server
                .post("/api/auth/register")
                .json(&json!({"username": "testuser", "password": test_password()}))
                .await;

            let auth_token = if reg_resp.status_code().is_success() {
                reg_resp.json::<serde_json::Value>()["token"]
                    .as_str().unwrap_or_default().to_string()
            } else {
                server
                    .post("/api/auth/login")
                    .json(&json!({"username": "testuser", "password": test_password()}))
                    .await
                    .json::<serde_json::Value>()["token"]
                    .as_str().unwrap_or_default().to_string()
            };
{% elif authentication == 'keycloak' -%}
            let kc_url = std::env::var("KEYCLOAK_URL").unwrap();
            let client = reqwest::Client::new();
            let tok_resp: serde_json::Value = client
                .post(format!("{}/realms/master/protocol/openid-connect/token", kc_url))
                .form(&[
                    ("client_id", "admin-cli"),
                    ("username", "admin"),
                    ("password", "admin"),
                    ("grant_type", "password"),
                ])
                .send().await.expect("keycloak token request failed")
                .json().await.expect("keycloak token parse failed");
            let auth_token = tok_resp["access_token"].as_str().unwrap().to_string();
{% endif -%}

            TestInfra {
                server,
{% if authentication == 'jwt' or authentication == 'keycloak' -%}
                auth_token,
{% endif -%}
{% if database == 'postgres' -%}
                _container: container,
{% endif -%}
{% if authentication == 'keycloak' -%}
                _keycloak: keycloak,
{% endif -%}
            }
        })
    })
}

/// Lazily generates and caches a unique password for this test run so that no
/// hardcoded credentials appear in the compiled binary or its output.
static TEST_PASSWORD: OnceLock<String> = OnceLock::new();

fn test_password() -> &'static str {
    TEST_PASSWORD.get_or_init(|| {
        use std::time::{SystemTime, UNIX_EPOCH};
        let ms = SystemTime::now()
            .duration_since(UNIX_EPOCH)
            .unwrap_or_default()
            .as_millis();
        format!("Tp{ms}A!")
    })
}

