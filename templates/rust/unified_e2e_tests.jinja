{% elif attr_prop.maxLength is defined and attr_prop.maxLength <= 10 -%}
            "{{ attr_name | snake_case }}": format!("{:.*}", {{ attr_prop.maxLength }}, format!("r{}", suffix)),
{% else -%}
            "{{ attr_name | snake_case }}": format!("RLS {} {}", "{{ attr_name | title }}", suffix),
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(42) }},
{% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default('true') | lower }},
{% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": format!("RLS {} content {}", "{{ attr_name | title }}", suffix),
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') }}",
{% endif -%}
{% endif -%}
{% endfor -%}
        })
    }

    /// Helper: create an entity under a specific tenant, returning the parsed JSON body.
    async fn create_as_tenant(i: &TestInfra, tenant: &str, payload: &serde_json::Value) -> serde_json::Value {
        let mut req = i.server.post("/api/{{ rls_plural }}").json(payload);
{% if authentication != 'none' -%}
        req = req.add_header("Authorization", format!("Bearer {}", i.auth_token));
{% endif -%}
        req = req.add_header("X-Tenant-Id", tenant);
        let resp = req.await;
        assert!(
            resp.status_code().is_success(),
            "create_as_tenant({}) failed: {} – {:?}",
            tenant, resp.status_code(), resp.text()
        );
