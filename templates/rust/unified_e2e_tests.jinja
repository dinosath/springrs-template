/// Tests for the authentication endpoints.
#[cfg(test)]
mod auth_tests {
    use super::*;

    #[test]
    fn test_register_returns_token() {
        let i = infra();
        shared_runtime().block_on(async {
            let response = i.server
                .post("/api/auth/register")
                .json(&json!({"username": "auth_reg_user", "password": test_password()}))
                .await;
            assert!(
                response.status_code().is_success(),
                "register failed: {} – {:?}",
                response.status_code(),
                response.text()
            );
            let body: serde_json::Value = response.json();
            assert!(body["token"].is_string(), "expected 'token' in register response, got: {:?}", body);
        });
    }

    #[test]
    fn test_login_returns_token() {
        let i = infra();
        shared_runtime().block_on(async {
            let _ = i.server
                .post("/api/auth/register")
                .json(&json!({"username": "auth_login_user", "password": test_password()}))
                .await;
            let response = i.server
                .post("/api/auth/login")
                .json(&json!({"username": "auth_login_user", "password": test_password()}))
                .await;
            assert!(
                response.status_code().is_success(),
                "login failed: {} – {:?}",
                response.status_code(),
                response.text()
            );
            let body: serde_json::Value = response.json();
            assert!(body["token"].is_string(), "expected 'token' in login response, got: {:?}", body);
        });
    }

    #[test]
    fn test_login_wrong_password_rejected() {
        let i = infra();
        shared_runtime().block_on(async {
            let _ = i.server
                .post("/api/auth/register")
                .json(&json!({"username": "auth_bad_pw_user", "password": test_password()}))
                .await;
            let response = i.server
                .post("/api/auth/login")
                .json(&json!({"username": "auth_bad_pw_user", "password": "WrongPassword!"}))
                .await;
            assert_eq!(response.status_code().as_u16(), 401, "expected 401 for wrong password");
        });
    }

    #[test]
    fn test_me_returns_user_info() {
        let i = infra();
        shared_runtime().block_on(async {
            let response = i.server
                .get("/api/auth/me")
                .add_header("Authorization", format!("Bearer {}", i.auth_token))
                .await;
            assert!(
                response.status_code().is_success(),
                "/api/auth/me failed: {} – {:?}",
                response.status_code(),
                response.text()
            );
            let body: serde_json::Value = response.json();
            assert!(body["user_id"].is_string(), "expected 'user_id' in /api/auth/me response, got: {:?}", body);
        });
    }

    #[test]
    fn test_me_without_token_rejected() {
        let i = infra();
        shared_runtime().block_on(async {
            let response = i.server.get("/api/auth/me").await;
            assert_eq!(response.status_code().as_u16(), 401, "expected 401 without auth token");
        });
    }

    #[test]
    fn test_logout_succeeds() {
        let i = infra();
        shared_runtime().block_on(async {
            let response = i.server.post("/api/auth/logout").await;
            assert!(response.status_code().is_success(), "logout failed: {}", response.status_code());
        });
    }
}
