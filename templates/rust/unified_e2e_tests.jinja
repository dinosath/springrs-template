            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endfor -%}
        });

        let mut create_request = server.post("/api/{{ entity_plural }}").json(&payload);
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        create_request = create_request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let create_response = create_request.await;
        let created: serde_json::Value = create_response.json();
        let id = &created["id"];

        // Delete the entity
        let mut delete_request = server.delete(&format!("/api/{{ entity_plural }}/{}", id));
{% if authentication != 'none' -%}
        delete_request = delete_request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let response = delete_request.await;
        
        assert!(
            response.status_code().is_success() || response.status_code().as_u16() == 204,
            "Failed to delete {{ entity_snake }}: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        // Verify it's deleted
        let mut get_request = server.get(&format!("/api/{{ entity_plural }}/{}", id));
{% if authentication != 'none' -%}
        get_request = get_request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
