{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
// REST CRUD tests
//
// Per-entity REST API tests: create, list, get, update, delete.

{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_protos = entity.protocols | default(protocols) -%}
{% if 'rest' in entity_protos -%}
{% set entity_snake = entity_name | snake_case -%}
{% set entity_plural = entity.info.pluralName | default(entity_name | plural | snake_case) -%}

/// Tests for {{ entity_name }} entity
mod {{ entity_snake }}_tests {
    use super::*;

    #[tokio::test]
    async fn test_create_{{ entity_snake }}() {
        let server = init_test_server().await;
        
        let payload = json!({
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
            "{{ attr_name | snake_case }}": "test_{{ entity_snake }}@example.com",
{% else -%}
            "{{ attr_name | snake_case }}": "Test {{ attr_name | title }}",
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(1) }},
{% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default('true') | lower }},
{% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": "Test {{ attr_name | title }} content",
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endfor -%}
        });

        let mut request = server.post("/api/{{ entity_plural }}").json(&payload);
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        request = request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let response = request.await;
        
        assert!(
            response.status_code().is_success(),
            "Failed to create {{ entity_snake }}: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let created: serde_json::Value = response.json();
        assert!(created["id"].is_number() || created["id"].is_string());
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
        assert_eq!(created["{{ attr_name | snake_case }}"], payload["{{ attr_name | snake_case }}"]);
{% endif -%}
{% endfor -%}
    }

    #[tokio::test]
    async fn test_list_{{ entity_plural }}() {
        let server = init_test_server().await;

        let mut request = server.get("/api/{{ entity_plural }}");
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        request = request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let response = request.await;
        
        assert!(
            response.status_code().is_success(),
            "Failed to list {{ entity_plural }}: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let list: serde_json::Value = response.json();
        assert!(list.is_array() || list["data"].is_array());
    }

    #[tokio::test]
    async fn test_get_{{ entity_snake }}() {
        let server = init_test_server().await;

        // First create an entity
        let payload = json!({
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
            "{{ attr_name | snake_case }}": "test_get_{{ entity_snake }}@example.com",
{% else -%}
            "{{ attr_name | snake_case }}": "Test Get {{ attr_name | title }}",
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(2) }},
{% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default('true') | lower }},
{% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": "Test Get {{ attr_name | title }} content",
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endfor -%}
        });

        let mut create_request = server.post("/api/{{ entity_plural }}").json(&payload);
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        create_request = create_request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let create_response = create_request.await;
        let created: serde_json::Value = create_response.json();
        let id = &created["id"];

        // Now get the entity
        let mut get_request = server.get(&format!("/api/{{ entity_plural }}/{}", id));
{% if authentication != 'none' -%}
        get_request = get_request.add_header("Authorization".parse().unwrap(), format!("Bearer {}", token).parse().unwrap());
{% endif -%}
        
        let response = get_request.await;
        
        assert!(
            response.status_code().is_success(),
            "Failed to get {{ entity_snake }}: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let fetched: serde_json::Value = response.json();
        assert_eq!(fetched["id"], *id);
