#[cfg(test)]
mod rls_tests {
    use super::*;

    /// Helper: build a JSON payload for the RLS test entity ({{ ns.rls_entity_name }}).
    fn rls_entity_payload(suffix: &str) -> serde_json::Value {
        json!({
{% for attr_name, attr_prop in ns.rls_entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
