    #[tokio::test]
    async fn test_rest_create_populates_outbox() {
        let server = init_test_server().await;
        let outbox_before = get_outbox(server).await;
        let _created = create_{{ entity_snake }}_fixture(server).await;
        let outbox_after = get_outbox(server).await;

        assert!(
            outbox_after.len() > outbox_before.len(),
            "Outbox should grow after REST create (before={}, after={})",
            outbox_before.len(),
            outbox_after.len()
        );

        let activity = find_activity(&outbox_after, "Create", "{{ entity_plural_kebab }}")
            .expect("Outbox should contain a Create activity for {{ entity_plural_kebab }}");
        assert_eq!(activity["type"], "Create");
        assert!(activity["actor"].is_string());
        assert!(activity["published"].is_string());
        assert!(activity["object"]["content"].is_object(), "Create activity should carry entity data");
    }

