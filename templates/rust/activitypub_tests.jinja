    /// Helper: get the current outbox items.
    async fn get_outbox(server: &TestServer) -> Vec<serde_json::Value> {
        let response = server.get("/ap/actor/outbox").await;
        assert!(response.status_code().is_success());
        let body: serde_json::Value = response.json();
        body["orderedItems"]
            .as_array()
            .cloned()
            .unwrap_or_default()
    }

    /// Helper: get the current inbox log items.
    async fn get_inbox_log(server: &TestServer) -> Vec<serde_json::Value> {
        let response = server.get("/ap/actor/inbox-log").await;
        assert!(response.status_code().is_success());
        let body: serde_json::Value = response.json();
        body["items"]
            .as_array()
            .cloned()
            .unwrap_or_default()
    }

    /// Helper: find the last outbox activity matching the given type and entity type.
    fn find_activity<'a>(
        items: &'a [serde_json::Value],
        activity_type: &str,
        entity_type: &str,
    ) -> Option<&'a serde_json::Value> {
        items.iter().rev().find(|item| {
            item["type"].as_str() == Some(activity_type)
                && item.get("object")
                    .and_then(|o| o.get("entityType"))
                    .and_then(|v| v.as_str())
                    == Some(entity_type)
        })
    }

