        let server = init_test_server().await;

        // Instance A: create entity via REST
        let created = create_{{ entity_snake }}_fixture(server).await;

        // Capture the generated Create activity from the outbox
        let outbox = get_outbox(server).await;
        let create_activity = find_activity(&outbox, "Create", "{{ entity_plural_kebab }}")
            .expect("Outbox should contain a Create activity");

        // Instance B: receive the Create activity via inbox
        let inbox_before = get_inbox_log(server).await;
        let response = server
            .post("/ap/actor/inbox")
            .json(create_activity)
            .add_header(
                "Content-Type",
                "application/activity+json",
            )
            .await;

        assert!(
            response.status_code().as_u16() == 202 || response.status_code().is_success(),
            "Inbox should accept the forwarded Create activity: status={}",
            response.status_code()
        );

        let inbox_after = get_inbox_log(server).await;
        assert!(
            inbox_after.len() > inbox_before.len(),
            "Inbox log should grow after federation roundtrip"
        );
    }

