/// Tests for ActivityPub discovery endpoints (WebFinger, server actor, outbox).
mod activitypub_discovery_tests {
    use super::*;

    #[tokio::test]
    async fn test_webfinger() {
        let server = init_test_server().await;
        let response = server
            .get("/.well-known/webfinger?resource=acct:test@localhost")
            .await;

        assert!(
            response.status_code().is_success(),
            "WebFinger failed: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let body: serde_json::Value = response.json();
        assert!(body["subject"].is_string(), "Expected 'subject' in WebFinger response");
        assert!(body["links"].is_array(), "Expected 'links' array in WebFinger response");
        assert!(body["aliases"].is_array(), "Expected 'aliases' array in WebFinger response");
    }

    #[tokio::test]
    async fn test_server_actor() {
        let server = init_test_server().await;
        let response = server
            .get("/ap/actor")
            .add_header(
                "Accept",
                "application/activity+json",
            )
            .await;

        assert!(
            response.status_code().is_success(),
            "Server actor failed: status={}",
            response.status_code()
        );

        let body: serde_json::Value = response.json();
        assert!(body["@context"].is_array() || body["@context"].is_string(),
            "Actor should have an @context");
        assert_eq!(body["type"], "Application");
        assert!(body["inbox"].is_string(), "Actor should have an inbox");
        assert!(body["outbox"].is_string(), "Actor should have an outbox");
        assert!(body["publicKey"].is_object(), "Actor should have a publicKey for HTTP signatures");
        assert!(body["publicKey"]["publicKeyPem"].is_string(), "publicKey should contain publicKeyPem");
    }

    #[tokio::test]
    async fn test_server_inbox_accepts_activity() {
        let server = init_test_server().await;
        let activity = json!({
            "@context": "https://www.w3.org/ns/activitystreams",
            "type": "Follow",
            "actor": "https://remote.example/users/bob",
            "object": "https://localhost/ap/actor",
        });

        let response = server
            .post("/ap/actor/inbox")
            .json(&activity)
            .add_header(
                "Content-Type",
                "application/activity+json",
            )
            .await;

        assert!(
            response.status_code().as_u16() == 202 || response.status_code().is_success(),
            "Server inbox should accept activity: status={}",
            response.status_code()
        );
    }

    #[tokio::test]
    async fn test_server_outbox() {
        let server = init_test_server().await;
        let response = server
            .get("/ap/actor/outbox")
            .add_header(
                "Accept",
                "application/activity+json",
            )
            .await;

        assert!(
            response.status_code().is_success(),
            "Server outbox failed: status={}",
            response.status_code()
        );

        let body: serde_json::Value = response.json();
        assert_eq!(body["type"], "OrderedCollection");
        assert!(body["orderedItems"].is_array());
