    /// 6. REST create → AP outbox → verify via gRPC.
    #[tokio::test]
    async fn test_rest_create_then_grpc_verify_with_ap_outbox() {
        let server = init_test_server().await;

        // Create via REST
        let created = create_{{ entity_snake }}_via_rest(server).await;
        let id_str = created["id"].as_i64().map(|i| i.to_string()).unwrap_or_default();

        // Verify AP outbox has the Create activity
        let outbox = get_outbox(server).await;
        assert!(
            outbox.iter().any(|a| a["type"] == "Create"),
            "Outbox should contain a Create activity"
        );

        // Verify via gRPC Get
        let grpc_get = server
            .post("/grpc/{{ project_name | snake_case }}.{{ entity_pascal }}Service/Get")
            .content_type("application/json")
            .json(&json!({"id": id_str}))
            .await;

        assert!(
            grpc_get.status_code().is_success(),
            "gRPC Get should succeed: status={}, body={:?}",
            grpc_get.status_code(),
            grpc_get.text()
        );
    }
{% endif -%}

    /// 7. Full federation roundtrip: REST create → outbox → inbox → verify.
    #[tokio::test]
    async fn test_full_federation_roundtrip_across_protocols() {
        let server = init_test_server().await;

        // Instance A: Create via REST
        let created = create_{{ entity_snake }}_via_rest(server).await;
        assert!(created["id"].is_number() || created["id"].is_string());

        // Instance A's outbox should have the Create activity
        let outbox = get_outbox(server).await;
        let create_activity = outbox.iter().rev().find(|a| {
            a["type"] == "Create"
                && a.get("object")
                    .and_then(|o| o.get("entityType"))
                    .and_then(|v| v.as_str())
                    == Some("{{ entity_plural_kebab }}")
        }).expect("Outbox should contain Create activity");

        // Instance B: Receive the Create activity via inbox
        let inbox_response = server
            .post("/ap/actor/inbox")
            .json(create_activity)
            .add_header(
                "Content-Type",
                "application/activity+json",
            )
            .await;

        assert!(
            inbox_response.status_code().as_u16() == 202 || inbox_response.status_code().is_success(),
            "Instance B inbox should accept forwarded Create: status={}",
            inbox_response.status_code()
        );

        // Verify inbox log recorded the activity
        let inbox_log_response = server.get("/ap/actor/inbox-log").await;
        assert!(inbox_log_response.status_code().is_success());
        let inbox_log: serde_json::Value = inbox_log_response.json();
        assert!(
            inbox_log["totalItems"].as_u64().unwrap_or(0) > 0,
            "Inbox log should contain at least one activity after federation roundtrip"
        );
    }
