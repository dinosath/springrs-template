{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
// Mixed-protocol integration tests
//
// These tests verify cross-protocol workflows where REST mutations trigger
// ActivityPub activities visible in the server outbox, and incoming AP
// activities to the server inbox result in database changes observable
// through REST and gRPC endpoints.

{% set ns = namespace(found_entity=false, entity_name='', entity=none) -%}
{# Find the first entity that supports activitypub + rest (+ optionally grpc) #}
{% for ename, ent in entities | items | selectattr("1.attributes") -%}
{% set eprotos = ent.protocols | default(protocols) -%}
{% if not ns.found_entity and 'activitypub' in eprotos and 'rest' in eprotos -%}
{% set ns.found_entity = true -%}
{% set ns.entity_name = ename -%}
{% set ns.entity = ent -%}
{% endif -%}
{% endfor -%}

{% if ns.found_entity -%}
{% set entity_name = ns.entity_name -%}
{% set entity = ns.entity -%}
{% set entity_protos = entity.protocols | default(protocols) -%}
{% set entity_snake = entity_name | snake_case -%}
{% set entity_pascal = entity_name | pascal_case -%}
{% set entity_plural = entity.info.pluralName | default(entity_name | plural | snake_case) -%}
{% set entity_plural_kebab = entity.info.pluralName | kebab_case -%}
{% set entity_plural_snake = entity_plural | snake_case -%}
{% set has_grpc = 'grpc' in entity_protos -%}

/// Mixed-protocol integration tests using {{ entity_name }} as the shared resource.
///
/// Flow:
/// 1. Perform mutations via REST and verify AP activities appear in the server outbox.
/// 2. Send AP activities to the server inbox and verify data changes via REST/gRPC.
mod mixed_protocol_{{ entity_snake }}_tests {
    use super::*;

    /// Helper: create a {{ entity_snake }} via REST.
    async fn create_{{ entity_snake }}_via_rest(server: &TestServer) -> serde_json::Value {
        let payload = json!({
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
            "{{ attr_name | snake_case }}": "mixed_test_{{ entity_snake }}@example.com",
{% else -%}
            "{{ attr_name | snake_case }}": "Mixed Test {{ attr_name | title }}",
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(1) }},
{% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default('true') | lower }},
{% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": "Mixed Test {{ attr_name | title }} content",
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endfor -%}
        });

        let mut request = server.post("/api/{{ entity_plural_kebab }}").json(&payload);
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        request = request.add_header("Authorization", format!("Bearer {}", token));
{% endif -%}
        let response = request.await;
        assert!(
            response.status_code().is_success(),
            "REST create {{ entity_snake }} failed: status={}, body={:?}",
            response.status_code(),
            response.text()
        );
        response.json::<serde_json::Value>()
    }

    /// Helper: get the current outbox items.
    async fn get_outbox(server: &TestServer) -> Vec<serde_json::Value> {
        let response = server.get("/ap/actor/outbox").await;
        assert!(response.status_code().is_success());
        let body: serde_json::Value = response.json();
        body["orderedItems"]
            .as_array()
            .cloned()
            .unwrap_or_default()
    }

    /// 1. REST Create produces an AP Create activity in the server outbox.
    #[tokio::test]
    async fn test_rest_create_produces_ap_create_activity() {
        let server = init_test_server().await;
        let outbox_before = get_outbox(server).await;

        let created = create_{{ entity_snake }}_via_rest(server).await;
        assert!(created["id"].is_number() || created["id"].is_string());

        let outbox_after = get_outbox(server).await;
        assert!(
            outbox_after.len() > outbox_before.len(),
            "Server outbox should grow after REST create"
        );

        // Find the Create activity
        let activity = outbox_after.iter().rev().find(|a| {
            a["type"] == "Create"
                && a.get("object")
                    .and_then(|o| o.get("entityType"))
                    .and_then(|v| v.as_str())
                    == Some("{{ entity_plural_kebab }}")
        });
        assert!(activity.is_some(), "Outbox should contain a Create activity for {{ entity_plural_kebab }}");
    }

    /// 2. REST Update produces an AP Update activity in the server outbox.
    #[tokio::test]
    async fn test_rest_update_produces_ap_update_activity() {
        let server = init_test_server().await;
        let created = create_{{ entity_snake }}_via_rest(server).await;
        let id = &created["id"];

        let update_payload = json!({
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
            "{{ attr_name | snake_case }}": "mixed_updated_{{ entity_snake }}@example.com",
{% else -%}
            "{{ attr_name | snake_case }}": "Mixed Updated {{ attr_name | title }}",
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(42) }},
{% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ 'false' if attr_prop.default == 'true' else 'true' }},
{% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": "Mixed Updated {{ attr_name | title }} content",
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
{% if attr_prop.enum | length > 1 -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[1] | pascal_case }}",
{% else -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endif -%}
{% endfor -%}
        });

        let mut request = server.put(&format!("/api/{{ entity_plural_kebab }}/{}", id)).json(&update_payload);
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        request = request.add_header("Authorization", format!("Bearer {}", token));
{% endif -%}
        let response = request.await;
        assert!(response.status_code().is_success(), "Update failed: {}", response.status_code());

        let outbox = get_outbox(server).await;
        let activity = outbox.iter().rev().find(|a| {
            a["type"] == "Update"
                && a.get("object")
                    .and_then(|o| o.get("entityType"))
                    .and_then(|v| v.as_str())
                    == Some("{{ entity_plural_kebab }}")
        });
        assert!(activity.is_some(), "Outbox should contain an Update activity for {{ entity_plural_kebab }}");
    }

    /// 3. REST Delete produces an AP Delete activity in the server outbox.
    #[tokio::test]
    async fn test_rest_delete_produces_ap_delete_activity() {
        let server = init_test_server().await;
        let created = create_{{ entity_snake }}_via_rest(server).await;
        let id = &created["id"];

        let mut request = server.delete(&format!("/api/{{ entity_plural_kebab }}/{}", id));
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        request = request.add_header("Authorization", format!("Bearer {}", token));
{% endif -%}
        let response = request.await;
        assert_eq!(response.status_code().as_u16(), 204, "Delete failed: {}", response.status_code());

        let outbox = get_outbox(server).await;
        let activity = outbox.iter().rev().find(|a| {
            a["type"] == "Delete"
                && a.get("object")
                    .and_then(|o| o.get("entityType"))
                    .and_then(|v| v.as_str())
                    == Some("{{ entity_plural_kebab }}")
        });
        assert!(activity.is_some(), "Outbox should contain a Delete activity for {{ entity_plural_kebab }}");
    }

    /// 4. AP inbox Create activity → entity accessible via REST.
    #[tokio::test]
    async fn test_ap_inbox_create_then_rest_read() {
        let server = init_test_server().await;

        // Send a Create activity to the server inbox (simulating federation)
        let create_activity = json!({
            "@context": "https://www.w3.org/ns/activitystreams",
            "type": "Create",
            "id": "https://remote.example/activities/mixed-create-{{ entity_snake }}",
            "actor": "https://remote.example/ap/actor",
            "published": "2025-01-01T00:00:00Z",
            "object": {
                "@context": "https://www.w3.org/ns/activitystreams",
                "type": "Object",
                "id": "https://remote.example/ap/{{ entity_plural_kebab }}/1",
                "attributedTo": "https://remote.example/ap/actor",
                "entityType": "{{ entity_plural_kebab }}",
                "entityId": "1",
                "content": {
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
                    "{{ attr_name | snake_case }}": "mixed_inbox_{{ entity_snake }}@remote.example",
{% else -%}
                    "{{ attr_name | snake_case }}": "Mixed Inbox {{ attr_name | title }}",
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
                    "{{ attr_name | snake_case }}": {{ attr_prop.default | default(1) }},
{% elif attr_prop.type == 'boolean' -%}
                    "{{ attr_name | snake_case }}": {{ attr_prop.default | default('true') | lower }},
{% elif attr_prop.type == 'text' -%}
                    "{{ attr_name | snake_case }}": "Mixed Inbox {{ attr_name | title }} content",
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
                    "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] | default('default') | pascal_case }}",
{% endif -%}
{% endif -%}
{% endfor -%}
                }
            }
        });

        let response = server
            .post("/ap/actor/inbox")
            .json(&create_activity)
            .add_header(
                "Content-Type",
                "application/activity+json",
            )
            .await;

        assert!(
            response.status_code().as_u16() == 202 || response.status_code().is_success(),
            "Server inbox should accept Create activity: status={}",
            response.status_code()
        );

        // Verify the entity was created and is accessible via REST list
        let mut list_request = server.get("/api/{{ entity_plural_kebab }}");
{% if authentication != 'none' -%}
        let token = get_auth_token(server).await;
        list_request = list_request.add_header("Authorization", format!("Bearer {}", token));
{% endif -%}
        let list_response = list_request.await;
        assert!(list_response.status_code().is_success(), "REST list should succeed after inbox Create");
        let list: Vec<serde_json::Value> = list_response.json();
        assert!(!list.is_empty(), "REST list should contain at least one entity after inbox Create");
    }

