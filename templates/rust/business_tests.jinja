/// Workflow tests for **{{ header_name }}** (detected as a financial-document entity).
///
/// Line entity: `{{ first_line_name if first_line_name else "none" }}`
/// Contact FK : `{{ hcontact.fk if hcontact.fk else "none" }}`
/// State field: `{{ h_state_f if h_state_f else "none" }}`
#[cfg(test)]
mod {{ h_snake }}_document_workflow_tests {
    use super::*;

    /// Creating a `{{ header_name }}` stores all amount fields with non-negative values.
    #[test]
    fn test_create_{{ h_snake }}_stores_amounts() {
        let i = infra();
        shared_runtime().block_on(async {
            let doc    = create_{{ h_snake }}(i).await;
            let doc_id = id_of(&doc);
            assert!(doc_id > 0, "{{ header_name }} id must be positive, got {doc_id}");
{% if h_total_f -%}
            assert!(
                f64_of(&doc, "{{ h_total_f }}") >= 0.0,
                "{{ header_name }}.{{ h_total_f }} must be >= 0"
            );
{% endif -%}
{% if h_net_f and h_total_f -%}
            // total must be >= net (tax/surcharges can only add to it)
            let net   = f64_of(&doc, "{{ h_net_f }}");
            let total = f64_of(&doc, "{{ h_total_f }}");
            if net > 0.0 && total > 0.0 {
                assert!(total >= net,
                    "{{ header_name }}.{{ h_total_f }} ({total}) must be >= .{{ h_net_f }} ({net})");
            }
{% endif -%}
        });
    }

    /// After creation, a `{{ header_name }}` is retrievable by its ID.
    #[test]
    fn test_get_{{ h_snake }}_by_id() {
        let i = infra();
        shared_runtime().block_on(async {
            let doc    = create_{{ h_snake }}(i).await;
            let doc_id = id_of(&doc);

            let resp = do_get(i, &format!("/api/{{ h_plural }}/{doc_id}")).await;
            assert!(
                resp.status_code().is_success(),
                "GET /api/{{ h_plural }}/{doc_id} failed: {}",
                resp.status_code()
            );
            let body: serde_json::Value = resp.json();
            assert_eq!(body["id"], json!(doc_id), "id round-trip mismatch");
        });
    }

    /// A newly created `{{ header_name }}` appears in the list endpoint.
    #[test]
    fn test_{{ h_snake }}_appears_in_list() {
        let i = infra();
        shared_runtime().block_on(async {
            let doc    = create_{{ h_snake }}(i).await;
            let doc_id = id_of(&doc);

            let resp = do_get(i, "/api/{{ h_plural }}?page_size=100").await;
            assert!(resp.status_code().is_success(), "list {{ h_plural }} failed");
            let list: Vec<serde_json::Value> = resp.json();
            assert!(
                list.iter().any(|d| id_of(d) == doc_id),
                "{{ header_name }} {doc_id} not found in list of {} entries",
                list.len()
            );
        });
    }

