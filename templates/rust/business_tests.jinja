// ── Shared infrastructure — one OnceLock per test binary ─────────────────────

fn shared_runtime() -> &'static tokio::runtime::Runtime {
    static RT: OnceLock<tokio::runtime::Runtime> = OnceLock::new();
    RT.get_or_init(|| {
        tokio::runtime::Builder::new_multi_thread()
            .enable_all()
            .build()
            .expect("failed to build shared tokio runtime for business tests")
    })
}

struct TestInfra {
    server: TestServer,
{% if authentication != 'none' -%}
    auth_token: String,
{% endif -%}
{% if database == 'postgres' -%}
    _container: ContainerAsync<Postgres>,
{% endif -%}
}

fn infra() -> &'static TestInfra {
    static INFRA: OnceLock<TestInfra> = OnceLock::new();
    INFRA.get_or_init(|| {
        shared_runtime().block_on(async {
{% if database == 'postgres' -%}
            let container = Postgres::default().start().await
                .expect("postgres container failed to start");
            let port = container.get_host_port_ipv4(5432).await
                .expect("postgres port unavailable");
            // SAFETY: called once at startup before any thread reads DATABASE_URL
            unsafe {
                std::env::set_var(
                    "DATABASE_URL",
                    format!("postgres://postgres:postgres@127.0.0.1:{port}/postgres"),
                );
            }
{% endif -%}
            let app = create_app().await.expect("failed to create app");
            let server = TestServer::new(app);
{% if authentication == 'jwt' -%}
            let pwd = biz_password();
            let reg = server
                .post("/api/auth/register")
                .json(&json!({"username": "biz_testuser", "password": pwd}))
                .await;
            let auth_token = if reg.status_code().is_success() {
                reg.json::<serde_json::Value>()["token"].as_str().unwrap_or_default().to_owned()
            } else {
                server
                    .post("/api/auth/login")
                    .json(&json!({"username": "biz_testuser", "password": pwd}))
                    .await
                    .json::<serde_json::Value>()["token"]
                    .as_str().unwrap_or_default().to_owned()
            };
{% endif -%}
            TestInfra {
                server,
{% if authentication != 'none' -%}
                auth_token,
{% endif -%}
{% if database == 'postgres' -%}
                _container: container,
{% endif -%}
            }
        })
    })
}

static BIZ_PASSWORD: OnceLock<String> = OnceLock::new();
fn biz_password() -> &'static str {
    BIZ_PASSWORD.get_or_init(|| {
        use std::time::{SystemTime, UNIX_EPOCH};
        let ms = SystemTime::now().duration_since(UNIX_EPOCH).unwrap_or_default().as_millis();
        format!("Biz{ms}!")
    })
}

/// Starts at 9000 to avoid colliding with the CRUD test binary (which starts at 1).
static BIZ_CTR: std::sync::atomic::AtomicU64 = std::sync::atomic::AtomicU64::new(9000);
fn next_suffix() -> String {
    BIZ_CTR.fetch_add(1, std::sync::atomic::Ordering::Relaxed).to_string()
}

// ── Utilities ────────────────────────────────────────────────────────────────

fn id_of(v: &serde_json::Value) -> i64 {
    v["id"].as_i64()
        .or_else(|| v["id"].as_str().and_then(|s| s.parse().ok()))
        .expect("response missing 'id'")
}

fn f64_of(v: &serde_json::Value, key: &str) -> f64 {
    v[key].as_f64()
        .or_else(|| v[key].as_str().and_then(|s| s.parse().ok()))
        .unwrap_or(0.0)
}

fn round2(x: f64) -> f64 { (x * 100.0).round() / 100.0 }

async fn do_post(i: &TestInfra, path: &str, body: &serde_json::Value) -> axum_test::TestResponse {
    let mut req = i.server.post(path).json(body);
{% if authentication != 'none' -%}
    req = req.add_header("Authorization", format!("Bearer {}", i.auth_token));
{% endif -%}
    req.await
}

