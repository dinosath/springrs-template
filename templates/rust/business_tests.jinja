{% import "macros.jinja" as macros -%}
{#
  business_tests.jinja
  ─────────────────────────────────────────────────────────────────────────────
  Generates `tests/business_tests.rs` — fully schema-driven business workflow
  integration tests.  No entity names, field names, or API routes are
  hard-coded in this template.  Everything is derived from the `entities`
  variable supplied by baker.

  Pattern-detection heuristics (all field-name checks are case-insensitive
  substring matches against the raw attribute key):

    "financial document"   entity with >= 2 numeric attributes whose names
                           contain any of: amount | total | net | vat
    "line item"            entity with a numeric "quantity*" attribute AND
                           at least one manyToOne FK
    "contact / partner"    entity with at least one email-format string attribute
    "state machine"        entity with an enum attribute named "state" or "status"

  Generated test modules (only rendered when the pattern is detected):
    {entity}_document_workflow_tests  — create header, add lines, verify sums,
                                        balance per contact, state transitions
    contact_management_tests          — create / update / validate contacts
    business_validation_tests         — 404s, required-field errors, auth, pagination
#}

{# ══════════════════════════════════════════════════════════════════════════
   §1  Jinja helper macros  (all field lookups are case-insensitive)
   ══════════════════════════════════════════════════════════════════════════ #}

{# snake_case name of the best "total" numeric field on an entity #}
{%- macro total_field(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'number' and ('total' in (fn | lower) or 'amount_total' in (fn | snake_case) or 'total_amount' in (fn | snake_case)) -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{%- if not m.f -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'number' and ('amount' in (fn | lower) or 'net' in (fn | lower)) -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{%- endif -%}
{{ m.f | trim }}
{%- endmacro -%}

{# snake_case name of the first "net / subtotal" numeric field #}
{%- macro net_field(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'number' and ('net' in (fn | lower) or 'subtotal' in (fn | lower)) -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# snake_case name of the first "vat / tax / duty" numeric field #}
{%- macro vat_field(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'number' and ('vat' in (fn | lower) or 'tax' in (fn | lower) or 'duty' in (fn | lower)) -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# snake_case name of the first "quantity*" numeric field #}
{%- macro qty_field(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and 'quantity' in (fn | lower) and fp.type == 'number' -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# snake_case name of the first "price / unit" numeric field #}
{%- macro price_field(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'number' and ('price' in (fn | lower) or 'unit' in (fn | lower)) -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# First enum value of the state/status field, or '' #}
{%- macro initial_state(ev) -%}
{%- set m = namespace(v='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.v and (fn | lower) in ['state', 'status'] and fp.enum -%}
{%- set m.v = fp.enum[0] -%}
{%- endif -%}
{%- endfor -%}
{{ m.v | trim }}
{%- endmacro -%}

{# Second enum value of the state/status field (the "next" state), or '' #}
{%- macro next_state(ev) -%}
{%- set m = namespace(v='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.v and (fn | lower) in ['state', 'status'] and fp.enum and fp.enum | length > 1 -%}
{%- set m.v = fp.enum[1] -%}
{%- endif -%}
{%- endfor -%}
{{ m.v | trim }}
{%- endmacro -%}

{# snake_case name of the state/status field, or '' #}
{%- macro state_field_name(ev) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and (fn | lower) in ['state', 'status'] and fp.enum -%}
{%- set m.f = fn | snake_case -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# snake_case FK field name pointing from ev -> target_name (manyToOne only) #}
{%- macro fk_to(ev, target_name) -%}
{%- set m = namespace(f='') -%}
{%- for fn, fp in ev.attributes | items -%}
{%- if not m.f and fp.type == 'relation' and fp.relation == 'manyToOne' and fp.target == target_name -%}
{%- set m.f = fn | snake_case ~ '_id' -%}
{%- endif -%}
{%- endfor -%}
{{ m.f | trim }}
{%- endmacro -%}

{# Emit a single JSON key/value for one non-relation attribute #}
{%- macro attr_value(fn, fp, prefix, sfx) -%}
{%- if fp.type == 'string' or fp.type == 'text' -%}
{%- if fp.format == 'email' -%}
            "{{ fn | snake_case }}": format!("{{ prefix }}_{}@example.com", {{ sfx }}),
{%- elif fp.format == 'date-time' or fp.format == 'date' -%}
            "{{ fn | snake_case }}": "2024-01-15T00:00:00",
{%- elif fp.maxLength is defined and fp.maxLength <= 10 -%}
            "{{ fn | snake_case }}": format!("{:.*}", {{ fp.maxLength }}, format!("v{}", {{ sfx }})),
{%- elif fp.enum -%}
            "{{ fn | snake_case }}": "{{ fp.enum[0] }}",
{%- else -%}
            "{{ fn | snake_case }}": format!("{{ prefix }} {{ fn | title }} {}", {{ sfx }}),
{%- endif -%}
{%- elif fp.type == 'integer' -%}
            "{{ fn | snake_case }}": {{ fp.default | default(1) }},
{%- elif fp.type == 'number' -%}
            "{{ fn | snake_case }}": {{ fp.default | default(0.0) }},
{%- elif fp.type == 'boolean' -%}
            "{{ fn | snake_case }}": {{ fp.default | default('true') | lower }},
{%- elif fp.enum or fp.type == 'enumeration' -%}
            "{{ fn | snake_case }}": "{{ fp.enum[0] }}",
{%- endif -%}
{%- endmacro -%}

{# ══════════════════════════════════════════════════════════════════════════
   §2  Entity pattern detection — purely from attributes, no hardcoded names
   ══════════════════════════════════════════════════════════════════════════ #}

{% set ns = namespace(header_names=[], line_names=[], contact_names=[], state_names=[]) -%}
{% for en, ev in entities | items -%}
{% if ev.attributes -%}
{% set scan = namespace(amount_count=0, has_qty=false, has_m2o=false, has_email=false, has_state=false) -%}
{% for fn, fp in ev.attributes | items -%}
{% if fp.type == 'number' and ('amount' in (fn | lower) or 'total' in (fn | lower) or 'net' in (fn | lower) or 'vat' in (fn | lower)) -%}{% set scan.amount_count = scan.amount_count + 1 -%}{% endif -%}
{% if 'quantity' in (fn | lower) and fp.type == 'number' -%}{% set scan.has_qty = true -%}{% endif -%}
{% if fp.type == 'relation' and fp.relation == 'manyToOne' -%}{% set scan.has_m2o = true -%}{% endif -%}
{% if fp.type == 'string' and fp.format == 'email' -%}{% set scan.has_email = true -%}{% endif -%}
{% if (fn | lower) in ['state', 'status'] and fp.enum -%}{% set scan.has_state = true -%}{% endif -%}
{% endfor -%}
{% if scan.amount_count >= 2 -%}{% set ns.header_names = ns.header_names + [en] -%}{% endif -%}
{% if scan.has_qty and scan.has_m2o -%}{% set ns.line_names = ns.line_names + [en] -%}{% endif -%}
{% if scan.has_email -%}{% set ns.contact_names = ns.contact_names + [en] -%}{% endif -%}
{% if scan.has_state -%}{% set ns.state_names = ns.state_names + [en] -%}{% endif -%}
{% endif -%}
{% endfor -%}

