min_version = "2024.1.0"

[tools]
rust = "latest"
"github:aliev/baker" = "latest"
"cargo:cargo-chef" = "latest"
"cargo:cargo-deny" = "latest"
"cargo:cargo-nextest" = "latest"
{{'protoc = "latest"' if 'grpc' in protocols }}
{{'helm = "latest"' if  "helm" in features }}
{{'node = "22"' if frontend == 'leptos' }}
{%- if frontend == 'leptos' %}
"cargo:trunk" = "latest"
{%- endif %}
jq = "latest"

[tasks.generate-local]
description = "Generate the project files from local repo"
run = "baker generate ../saas-templates . --answers-file .baker/answers.json --force --non-interactive --skip-confirms all"
sources = ['.baker/answers.json']

[tasks.generate]
description = "Generate the project files"
run = "baker generate https://github.com/dinosath/saas-templates . --answers-file .baker/answers.json --force --non-interactive --skip-confirms all"
sources = ['.baker/answers.json']

[tasks.baker-update]
description = "Update the project files from generated repo"
run = "baker update --non-interactive --skip-confirms all"
sources = ['.baker/answers.json']

{% if frontend == 'leptos' %}
[tasks.frontend-install]
description = "Install Leptos frontend npm dependencies"
dir = "frontend"
run = "npm install"

[tasks.frontend-build]
description = "Build Leptos frontend with Trunk"
dir = "frontend"
run = "trunk build --release"
depends = ["frontend-install"]
env = { CARGO = "~/.cargo/bin/cargo" }

[tasks.frontend-dev]
description = "Run Leptos frontend dev server"
dir = "frontend"
run = "trunk serve --open"
depends = ["frontend-install"]
{% elif frontend != "none" %}
[tasks.frontend-install]
description = "Install frontend npm dependencies"
dir = "frontend"
run = "npm install"

[tasks.frontend-dev]
description = "Run frontend dev server"
dir = "frontend"
run = "npm run dev"
depends = ["frontend-install"]

[tasks.frontend-build]
description = "Build frontend"
dir = "frontend"
run = "npm run build"
depends = ["frontend-install"]
{% endif %}

[tasks.build]
description = "Build the project"
run = "cargo build --release"
{{ 'depends = "frontend-build"' if frontend != "none" }}

[tasks.test]
description = "Run tests"
run = "cargo nextest run --all --test-threads 4"

[tasks.test-coverage]
description = "Run tests for coverage report"
run = "cargo tarpaulin --out Html --out Lcov --output-dir target/coverage"

[tasks.audit]
description = "Check for vulnerabilities using cargo deny"
run = "cargo deny check"

[tasks.cargo-chef]
description = "Run cargo chef to cache dependencies"
run = "cargo chef prepare --recipe-path recipe.json"

[tasks.docker-build]
description = "Build Docker images"
run = "docker build -t {{project_name}} ."
{{ 'depends = ["frontend-build"]' if frontend != "none" }}

[tasks.docker-push]
description = "Push Docker images"
run = "docker push -t {{project_name}} ."
depends = ["docker-build"]

[tasks.e2e]
description = "Run e2e tests"
sources = ['Cargo.toml', 'src/**/*.rs'] 
run = "cargo test"
dir = "e2e"
depends = ["docker-build"]

{% if  "helm" in features -%}
[tasks.helm-package]
description = "Package Helm chart"
dir="helm"
run = "helm package ."

[tasks.helm-push]
description = "Push Helm chart"
dir="helm"
run = "helm push {{ project_name | kebab_case }}"
depends = ["helm-package"]
{% endif %}
{% if add_migrations and orm == 'diesel' %}
[tasks.db-migrate]
description = "Run pending diesel migrations"
run = "diesel migration run"

[tasks.db-rollback]
description = "Revert the last diesel migration"
run = "diesel migration revert"

[tasks.db-redo]
description = "Revert then re-apply the last diesel migration"
run = "diesel migration redo"
{% endif %}
[tasks.post-generate]
description = "Post generation tasks"
run = '''
cargo fmt 
cargo fix --allow-dirty --allow-no-vcs
cargo update
'''

[tasks.build-and-test]
description = "Build and test the project"
run = [
    { task = "post-generate" },
    { task = "cargo-chef" },
    { tasks = ["test","audit"] },
    { task = "docker-build" },
    { task = "e2e" },
    {{ '{ task = "helm-package" },' if "helm" in features }}
]

[tasks.build-frontend-and-test]
description = "Build frontend and test the project"
run = [
    {{ '{ task = "frontend-build" },' if frontend != "none" }}
    { task = "post-generate" },
    { task = "cargo-chef" },
    { tasks = ["test","audit"] },
    { task = "docker-build" },
    { task = "e2e" },
    {{ '{ task = "helm-package" },' if "helm" in features }}
]

[tasks.generate-local-and-test]
description = "Generate the project and run tests"
depends = ["generate-local", "build-and-test"]

[tasks.generate-and-test]
description = "Generate the project and run tests"
depends = ["generate", "build-and-test"]

[tasks.ci]
description = "CI Task"
run = [
    {{ '{ task = "frontend-build" },' if frontend != "none" }}
    { task = "docker-build" },
    { tasks = ["docker-push"{{',"helm-push"' if "helm" in features }}] },
]