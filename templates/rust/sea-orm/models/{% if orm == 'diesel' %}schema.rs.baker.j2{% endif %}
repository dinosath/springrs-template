{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
diesel::table! {
    {% for name, property in entity.attributes | items | selectattr('1.enum') -%}
    {% if loop.first -%}
    use diesel::sql_types::*;
    {% endif -%}
    use super::super::{{ entity_name | snake_case }}::{{ name | pascal_case }}Mapping;
    {% if loop.last %}
    {% endif -%}
    {% endfor -%}
    {{ entity_name | table_case }} (id) {
        id -> Int4,
        created_at -> Timestamp,
        last_updated -> Timestamp,
        {% if macros.entity_has_rls(entity, row_level_security)|trim == 'true' -%}
        tenant_id -> Varchar,
        {% endif -%}
        {% for name, property in entity.attributes | items -%}
        {%- set col_name = rust_types.rust_var(name, false) -%}
        {%- set table_name = entity_name | table_case -%}
        {%- set safe_name = col_name if col_name != table_name else '_' ~ col_name -%}
        {%- if col_name == table_name and property.type != 'relation' %}
        #[sql_name = "{{ col_name }}"]
        {%- endif -%}
        {%- if property.type == 'relation' -%}
        {%- if macros.relation_is_many_to_one(property)=='true' or macros.relation_is_one_to_one(property)=='true' -%}
        {{ name | snake_case }}_id -> {% if not property.required %}Nullable<{% endif %}Int4{% if not property.required %}>{% endif %},
        {%- endif -%}
        {%- elif property.type == 'string' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Varchar{% if not property.required %}>{% endif %},
        {%- elif property.type == 'text' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Text{% if not property.required %}>{% endif %},
        {%- elif property.type == 'integer' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Int4{% if not property.required %}>{% endif %},
        {%- elif property.type == 'biginteger' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Int8{% if not property.required %}>{% endif %},
        {%- elif property.type == 'float' or property.type == 'decimal' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Float8{% if not property.required %}>{% endif %},
        {%- elif property.type == 'boolean' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Bool{% if not property.required %}>{% endif %},
        {%- elif property.type == 'datetime' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Timestamp{% if not property.required %}>{% endif %},
        {%- elif property.type == 'date' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Date{% if not property.required %}>{% endif %},
        {%- elif property.type == 'time' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Time{% if not property.required %}>{% endif %},
        {%- elif property.type == 'email' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Varchar{% if not property.required %}>{% endif %},
        {%- elif property.type == 'enumeration' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}{{ name | pascal_case }}Mapping{% if not property.required %}>{% endif %},
        {%- elif property.type == 'json' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Jsonb{% if not property.required %}>{% endif %},
        {%- elif property.type == 'uid' -%}
        {{ safe_name }} -> {% if not property.required %}Nullable<{% endif %}Uuid{% if not property.required %}>{% endif %},
        {%- endif -%}
        {% endfor %}
    }
}

{% endfor -%}

{% for relation in macros.get_m2m_relations(entities) | split(',') -%}
{% if relation | trim != '' -%}
{% set left = relation | split("_") | first -%}
{% set right = relation | split("_") | last -%}
diesel::table! {
    {{ relation | snake_case }} ({{ left | snake_case }}_id, {{ right | snake_case }}_id) {
        {{ left | snake_case }}_id -> Int4,
        {{ right | snake_case }}_id -> Int4,
    }
}

{% endif -%}
{% endfor -%}

{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% for name, property in entity.attributes | items -%}
{% if macros.relation_is_many_to_one(property)=='true' or macros.relation_is_one_to_one(property)=='true' -%}
diesel::joinable!({{ entity_name | table_case }} -> {{ property.target | table_case }} ({{ name | snake_case }}_id));
{% endif -%}
{% endfor -%}
{% endfor -%}

diesel::allow_tables_to_appear_in_same_query!(
    {% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
    {{ entity_name | table_case }},
    {% endfor -%}
    {% for relation in macros.get_m2m_relations(entities) | split(',') -%}
    {% if relation | trim != '' -%}
    {{ relation | snake_case }},
    {% endif -%}
    {% endfor -%}
);
