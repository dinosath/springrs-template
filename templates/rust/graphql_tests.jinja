    #[tokio::test]
    async fn test_graphql_get_{{ entity_snake }}() {
        let server = init_test_server().await;

        // First create via mutation
        let create_query = r#"mutation {
            create{{ entity_pascal }}(input: {
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if macros.relation_is_many_to_many(attr_prop) != 'true' and macros.relation_is_one_to_many(attr_prop) != 'true' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
                {{ attr_name | camel_case }}: "gql_gettest_{{ entity_snake }}@example.com"
{% else -%}
                {{ attr_name | camel_case }}: "GQL Get Test {{ attr_name | title }}"
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
                {{ attr_name | camel_case }}: {{ attr_prop.default | default(2) }}
{% elif attr_prop.type == 'boolean' -%}
                {{ attr_name | camel_case }}: {{ attr_prop.default | default('true') | lower }}
{% elif attr_prop.type == 'text' -%}
                {{ attr_name | camel_case }}: "GQL Get Test {{ attr_name | title }} content"
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
                {{ attr_name | camel_case }}: "{{ attr_prop.enum[0] | default('default') | pascal_case }}"
{% endif -%}
{% endif -%}
{% endif -%}
{% endfor -%}
            }) { id }
        }"#;

        let create_response = server
            .post("/graphql")
            .content_type("application/json")
            .json(&json!({"query": create_query}))
            .await;
        let create_body: serde_json::Value = create_response.json();
        let id = &create_body["data"]["create{{ entity_pascal }}"]["id"];

        // Now query by ID
        let get_query = format!(
            r#"query {{ "{{" }} {{ entity_snake }}(id: {}) {{ "{{" }} id {% for attr_name, attr_prop in entity.attributes | items -%}{% if not attr_prop.writeOnly and attr_prop.type != 'relation' -%}{% if macros.relation_is_many_to_many(attr_prop) != 'true' and macros.relation_is_one_to_many(attr_prop) != 'true' -%}{{ attr_name | camel_case }} {% endif -%}{% endif -%}{% endfor -%}{{ "}}" }} {{ "}}" }}"#,
            id
        );

        let response = server
            .post("/graphql")
            .content_type("application/json")
            .json(&json!({"query": get_query}))
            .await;

        assert!(
            response.status_code().is_success(),
            "GraphQL get {{ entity_snake }} failed: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let body: serde_json::Value = response.json();
        assert!(
            body["data"]["{{ entity_snake }}"].is_object() || body["data"]["{{ entity_snake }}"].is_null(),
            "Expected data.{{ entity_snake }} in response, got: {:?}",
            body
        );
    }

