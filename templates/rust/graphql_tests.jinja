{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
// GraphQL protocol tests
//
// Tests GraphQL queries and mutations for each entity, plus
// the playground endpoint.

{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_protos = entity.protocols | default(protocols) -%}
{% if 'graphql' in entity_protos -%}
{% set entity_snake = entity_name | snake_case -%}
{% set entity_pascal = entity_name | pascal_case -%}
{% set entity_plural = entity.info.pluralName | default(entity_name | plural | snake_case) -%}
{% set entity_plural_snake = entity_plural | snake_case -%}

/// GraphQL tests for {{ entity_name }}
mod {{ entity_snake }}_graphql_tests {
    use super::*;

    #[tokio::test]
    async fn test_graphql_create_{{ entity_snake }}() {
        let server = init_test_server().await;

        let query = r#"mutation {
            create{{ entity_pascal }}(input: {
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.readOnly and attr_prop.type != 'relation' -%}
{% if macros.relation_is_many_to_many(attr_prop) != 'true' and macros.relation_is_one_to_many(attr_prop) != 'true' -%}
{% if attr_prop.type == 'string' -%}
{% if attr_prop.format == 'email' -%}
                {{ attr_name | camel_case }}: "gql_test_{{ entity_snake }}@example.com"
{% else -%}
                {{ attr_name | camel_case }}: "GQL Test {{ attr_name | title }}"
{% endif -%}
{% elif attr_prop.type == 'integer' -%}
                {{ attr_name | camel_case }}: {{ attr_prop.default | default(1) }}
{% elif attr_prop.type == 'boolean' -%}
                {{ attr_name | camel_case }}: {{ attr_prop.default | default('true') | lower }}
{% elif attr_prop.type == 'text' -%}
                {{ attr_name | camel_case }}: "GQL Test {{ attr_name | title }} content"
{% elif attr_prop.type == 'enumeration' or attr_prop.enum -%}
                {{ attr_name | camel_case }}: "{{ attr_prop.enum[0] | default('default') | pascal_case }}"
{% endif -%}
{% endif -%}
{% endif -%}
{% endfor -%}
            }) {
                id
{% for attr_name, attr_prop in entity.attributes | items -%}
{% if not attr_prop.writeOnly and attr_prop.type != 'relation' -%}
{% if macros.relation_is_many_to_many(attr_prop) != 'true' and macros.relation_is_one_to_many(attr_prop) != 'true' -%}
                {{ attr_name | camel_case }}
{% endif -%}
{% endif -%}
{% endfor -%}
            }
        }"#;

        let response = server
            .post("/graphql")
            .content_type("application/json")
            .json(&json!({"query": query}))
            .await;

        assert!(
            response.status_code().is_success(),
            "GraphQL create {{ entity_snake }} failed: status={}, body={:?}",
            response.status_code(),
            response.text()
        );

        let body: serde_json::Value = response.json();
        assert!(
            body["data"]["create{{ entity_pascal }}"].is_object(),
            "Expected data.create{{ entity_pascal }} in response, got: {:?}",
            body
        );
        assert!(
            body["data"]["create{{ entity_pascal }}"]["id"].is_number()
                || body["data"]["create{{ entity_pascal }}"]["id"].is_string(),
            "Created {{ entity_snake }} should have an id"
        );
    }

