/// Tests for the GraphQL playground endpoint.
mod graphql_playground_tests {
    use super::*;

    #[tokio::test]
    async fn test_graphql_playground_accessible() {
        let server = init_test_server().await;
        let response = server.get("/graphql/playground").await;

        assert!(
            response.status_code().is_success(),
            "GraphQL playground should be accessible, got: {}",
            response.status_code()
        );

        let body = response.text();
        assert!(
            body.contains("graphql") || body.contains("GraphQL") || body.contains("playground"),
            "Expected GraphQL playground HTML"
        );
    }

    #[tokio::test]
    async fn test_graphql_introspection() {
        let server = init_test_server().await;

        let query = r#"{ __schema { queryType { name } mutationType { name } } }"#;
        let response = server
            .post("/graphql")
            .content_type("application/json")
            .json(&json!({"query": query}))
            .await;

        assert!(
            response.status_code().is_success(),
            "GraphQL introspection failed: status={}",
            response.status_code()
        );

        let body: serde_json::Value = response.json();
        assert!(
            body["data"]["__schema"]["queryType"]["name"].is_string(),
            "Expected introspection to return queryType name"
        );
    }
}
