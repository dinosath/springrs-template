pub fn routes() -> axum::Router<AppState> {
    use axum::routing::{get, post, put, delete};
    axum::Router::new()
        .route("/api/{{ entity.info.pluralName | kebab_case }}", get(list).post(create))
        .route("/api/{{ entity.info.pluralName | kebab_case }}/{id}", get(read_one).put(update).delete(remove))
}
