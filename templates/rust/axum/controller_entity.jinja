{% if ns.state_field_name %}
/// Request body for state transition endpoints.
#[derive(Debug, Deserialize)]
pub struct StateTransitionRequest {
    pub {{ ns.state_field_name }}: {{ ns.state_type_rust }},
}

/// Transition `{{ entity_name | snake_case }}` to a new `{{ ns.state_field_name }}` without touching other fields.
pub async fn set_state(State(state): State<AppState>, Path(item_id): Path<i32>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}, Json(req): Json<StateTransitionRequest>) -> Result<impl IntoResponse, (StatusCode, Json<serde_json::Value>)> {
    debug!("Transitioning {{ entity_name | snake_case }} {} state to {:?}", item_id, req.{{ ns.state_field_name }});

    {% if orm == 'seaorm' -%}
    use sea_orm::Set;
    let model = load_item(&state.db, item_id).await?;
    let mut active_model = model.into_active_model();
    active_model.{{ ns.state_field_name }} = Set(req.{{ ns.state_field_name }} as {{ ns.state_enum_type }});
    let model = active_model.update(&state.db).await
        .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": e.to_string()}))))?;
    {% elif orm == 'diesel' -%}
    let mut conn = state.pool.get()
        .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": e.to_string()}))))?;
    let _ = load_item(&mut conn, item_id)?;
    let model = diesel::update({{ entity_name | table_case }}::table.find(item_id))
        .set({{ entity_name | table_case }}::{{ ns.state_field_name }}.eq(&req.{{ ns.state_field_name }}))
        .get_result::<{{model}}>(&mut conn)
        .map_err(|e| (StatusCode::INTERNAL_SERVER_ERROR, Json(serde_json::json!({"error": e.to_string()}))))?;
    {% endif -%}

    debug!("Successfully transitioned {{ entity_name | snake_case }} {} to {:?}", item_id, req.{{ ns.state_field_name }});
    let resp: {{model}}Response = model.into();
    Ok(Json(resp))
}
{% endif %}

pub fn routes() -> axum::Router<AppState> {
    use axum::routing::{get{% if ns.state_field_name %}, patch{% endif %}};
    let router = axum::Router::new()
        .route("/api/{{ entity.info.pluralName | kebab_case }}", get(list).post(create))
        .route("/api/{{ entity.info.pluralName | kebab_case }}/{id}", get(read_one).put(update).delete(remove));
    {% if ns.state_field_name %}
    router.route("/api/{{ entity.info.pluralName | kebab_case }}/{id}/state", patch(set_state))
    {% else %}
    router
    {% endif %}
}
