# cargo-deny configuration
# See https://embarkstudios.github.io/cargo-deny/

[advisories]
# IDs of advisories to ignore
ignore = []

[licenses]
# Allow common open-source licenses
allow = [
    "MIT",
    "Apache-2.0",
    "Apache-2.0 WITH LLVM-exception",
    "BSD-2-Clause",
    "BSD-3-Clause",
    "ISC",
    "0BSD",
    "Zlib",
    "Unicode-DFS-2016",
    "Unicode-3.0",
    "OpenSSL",
    "CC0-1.0",
    "MPL-2.0",
    "CDLA-Permissive-2.0",
]

[bans]
# Warn on duplicate versions of the same crate
multiple-versions = "warn"

[sources]
unknown-registry = "warn"
unknown-git = "warn"
