use serde_json::{json, Value};

// ============================================================================
// Shared helpers
// ============================================================================

fn extract_id(val: &Value) -> i64 {
    val["id"].as_i64()
        .or_else(|| val["id"].as_str().and_then(|s| s.parse().ok()))
        .unwrap_or_else(|| panic!("no id in response: {:?}", val))
}
{% endif %}

{% if 'rest' in protocols %}
async fn api_post(client: &reqwest::Client, url: &str, body: &Value) -> Value {
    let resp = client.post(url).json(body).send().await
        .unwrap_or_else(|e| panic!("POST {} failed: {}", url, e));
    assert!(
        resp.status().is_success(),
        "POST {} returned {}: {:?}", url, resp.status(), resp.text().await.unwrap_or_default()
    );
    resp.json::<Value>().await.unwrap_or_else(|e| panic!("parse POST {} body: {}", url, e))
}

