async fn setup_grpc_{{ entity_snake }}(addr: &str) -> e2e::proto::{{ entity_pascal }} {
    {% for attr_name, attr_prop in entity.attributes | items -%}
    {% if macros.relation_is_many_to_one(attr_prop) == 'true' or (macros.relation_is_one_to_one(attr_prop) == 'true' and not attr_prop.mappedBy) -%}
    let {{ attr_name | snake_case }}_dep = setup_grpc_{{ attr_prop.target | snake_case }}(addr).await;
    {% endif -%}
    {% endfor -%}
    use e2e::proto::{{ entity_snake }}_service_client::{{ entity_pascal }}ServiceClient;
    let mut client = {{ entity_pascal }}ServiceClient::connect(addr.to_string())
        .await
        .expect("grpc connect {{ entity_snake }}");
    let resp = client
        .create(tonic::Request::new(e2e::proto::Create{{ entity_pascal }}Request {
            {% for attr_name, attr_prop in entity.attributes | items -%}
            {% if attr_prop.type == 'relation' -%}
                {% if macros.relation_is_many_to_one(attr_prop) == 'true' or (macros.relation_is_one_to_one(attr_prop) == 'true' and not attr_prop.mappedBy) -%}
            {{ attr_name | snake_case }}: Some({{ attr_name | snake_case }}_dep.id.clone()),
                {% endif -%}
            {% elif attr_name == 'created_at' or attr_name == 'updated_at' or attr_name == 'last_updated' -%}
            {# skip auto-managed fields - handled by ..Default::default() #}
            {% elif attr_prop.enum -%}
            {{ attr_name | snake_case }}: Some("{{ attr_prop.enum[0] }}".to_string()),
            {% elif attr_prop.type == 'string' -%}
                {% if attr_prop.format == 'email' -%}
            {{ attr_name | snake_case }}: Some("grpc_{{ entity_snake }}@example.com".to_string()),
                {% elif attr_prop.format == 'url' or attr_prop.format == 'uri' -%}
            {{ attr_name | snake_case }}: Some("https://example.com/grpc/{{ entity_snake }}".to_string()),
                {% elif attr_prop.format == 'date-time' or attr_prop.format == 'date' -%}
                {# optional datetime - skip, let default handle it #}
                {% else -%}
            {{ attr_name | snake_case }}: Some("grpc_{{ entity_snake }}_{{ attr_name | snake_case }}".to_string()),
                {% endif -%}
            {% elif attr_prop.type == 'text' -%}
            {{ attr_name | snake_case }}: Some("grpc {{ entity_snake }} {{ attr_name | snake_case }}".to_string()),
            {% elif attr_prop.type == 'integer' -%}
            {{ attr_name | snake_case }}: Some({{ attr_prop.default | default(1) }}),
            {% elif attr_prop.type == 'number' -%}
            {{ attr_name | snake_case }}: Some(1.0),
            {% elif attr_prop.type == 'boolean' -%}
            {{ attr_name | snake_case }}: Some({{ attr_prop.default | default(true) | lower }}),
            {% endif -%}
            {% endfor -%}
            ..Default::default()
        }))
        .await
        .expect("grpc create {{ entity_snake }}");
    resp.into_inner()
}

