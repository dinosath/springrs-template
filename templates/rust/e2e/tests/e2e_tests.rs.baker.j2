{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_snake = entity_name | snake_case -%}
{% set entity_plural = entity.info.pluralName | kebab_case -%}
mod {{ entity_snake }}_crud {
    use super::*;
    use e2e::{base_url, http_client};
    use rstest::rstest;

    #[rstest]
    #[tokio::test]
    async fn create(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let resp = setup_{{ entity_snake }}(&base_url, &http_client).await;
        assert!(resp["id"].as_i64().is_some() || resp["id"].as_str().is_some(),
            "Expected id in create response: {:?}", resp);
    }

    #[rstest]
    #[tokio::test]
    async fn list(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        // Ensure at least one item exists
        let _ = setup_{{ entity_snake }}(&base_url, &http_client).await;

        let resp = http_client
            .get(format!("{}/api/{{ entity_plural }}", base_url))
            .send().await.expect("GET {{ entity_plural }} failed");
        assert!(resp.status().is_success(), "List {{ entity_plural }} failed: {}", resp.status());
        let body: Value = resp.json().await.expect("parse list body");
        assert!(body.is_array(), "Expected array response for {{ entity_plural }}");
        assert!(!body.as_array().unwrap().is_empty(), "Expected non-empty list for {{ entity_plural }}");
    }

    #[rstest]
    #[tokio::test]
    async fn read_one(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let created = setup_{{ entity_snake }}(&base_url, &http_client).await;
        let id = extract_id(&created);

        let resp = http_client
            .get(format!("{}/api/{{ entity_plural }}/{}", base_url, id))
            .send().await.expect("GET {{ entity_plural }}/{id} failed");
        assert!(resp.status().is_success(), "read_one {{ entity_snake }} failed: {}", resp.status());
        let body: Value = resp.json().await.expect("parse read_one body");
        assert_eq!(body["id"].as_i64().unwrap_or(0), id, "returned id mismatch");
    }

    #[rstest]
    #[tokio::test]
    async fn update(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let created = setup_{{ entity_snake }}(&base_url, &http_client).await;
        let id = extract_id(&created);

        let update_body = json!({
            {% for attr_name, attr_prop in entity.attributes | items -%}
            {% if attr_prop.type == 'relation' -%}
                {% if macros.relation_is_many_to_one(attr_prop) == 'true' or (macros.relation_is_one_to_one(attr_prop) == 'true' and not attr_prop.mappedBy) -%}
            "{{ attr_name | snake_case }}_id": created["{{ attr_name | snake_case }}_id"],
                {% endif -%}
            {% elif attr_name == 'created_at' or attr_name == 'last_updated' -%}
            {% elif attr_prop.enum -%}
            "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] }}",
            {% elif attr_prop.type == 'string' -%}
                {% if attr_prop.format == 'email' -%}
            "{{ attr_name | snake_case }}": "updated_{{ entity_snake }}@example.com",
                {% elif attr_prop.format == 'url' or attr_prop.format == 'uri' -%}
            "{{ attr_name | snake_case }}": "https://example.com/updated/{{ entity_snake }}",
                {% elif attr_prop.format == 'date-time' or attr_prop.format == 'date' -%}
            {% if attr_prop.required -%}
            "{{ attr_name | snake_case }}": "2024-06-01T00:00:00",
            {% endif -%}
                {% else -%}
            "{{ attr_name | snake_case }}": "updated_{{ entity_snake }}_{{ attr_name | snake_case }}",
                {% endif -%}
            {% elif attr_prop.type == 'text' -%}
            "{{ attr_name | snake_case }}": "updated {{ entity_snake }} {{ attr_name | snake_case }} content",
            {% elif attr_prop.type == 'integer' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(2) }},
            {% elif attr_prop.type == 'number' -%}
            "{{ attr_name | snake_case }}": 2.0,
            {% elif attr_prop.type == 'boolean' -%}
            "{{ attr_name | snake_case }}": {{ attr_prop.default | default(true) | lower }},
            {% endif -%}
            {% endfor -%}
        });

        let resp = http_client
            .put(format!("{}/api/{{ entity_plural }}/{}", base_url, id))
            .json(&update_body)
            .send().await.expect("PUT {{ entity_plural }}/{id} failed");
        assert!(resp.status().is_success(), "update {{ entity_snake }} failed: {}", resp.status());
        let body: Value = resp.json().await.expect("parse update body");
        assert_eq!(body["id"].as_i64().unwrap_or(0), id, "updated id mismatch");
    }

    #[rstest]
    #[tokio::test]
    async fn delete(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let created = setup_{{ entity_snake }}(&base_url, &http_client).await;
        let id = extract_id(&created);

        let resp = http_client
            .delete(format!("{}/api/{{ entity_plural }}/{}", base_url, id))
            .send().await.expect("DELETE {{ entity_plural }}/{id} failed");
        assert!(resp.status().is_success(), "delete {{ entity_snake }} failed: {}", resp.status());

        // Confirm 404 after deletion
        let get_resp = http_client
            .get(format!("{}/api/{{ entity_plural }}/{}", base_url, id))
            .send().await.expect("GET after delete failed");
        assert_eq!(get_resp.status().as_u16(), 404, "Expected 404 after delete");
    }
}

