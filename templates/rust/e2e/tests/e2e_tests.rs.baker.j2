                    {% elif attr_prop.format == 'date-time' or attr_prop.format == 'date' -%}
                {# optional datetime - keep original value #}
                {{ attr_name | snake_case }}: created.{{ attr_name | snake_case }}.clone(),
                    {% else -%}
                {{ attr_name | snake_case }}: Some("updated_grpc_{{ entity_snake }}_{{ attr_name | snake_case }}".to_string()),
                    {% endif -%}
                {% elif attr_prop.type == 'text' -%}
                {{ attr_name | snake_case }}: Some("updated grpc {{ entity_snake }} {{ attr_name | snake_case }}".to_string()),
                {% elif attr_prop.type == 'integer' -%}
                {{ attr_name | snake_case }}: Some({{ attr_prop.default | default(2) }}),
                {% elif attr_prop.type == 'number' -%}
                {{ attr_name | snake_case }}: Some(2.0),
                {% elif attr_prop.type == 'boolean' -%}
                {{ attr_name | snake_case }}: created.{{ attr_name | snake_case }},
                {% endif -%}
                {% endfor -%}
                ..Default::default()
            }))
            .await
            .expect("grpc update {{ entity_snake }}");
        assert_eq!(resp.into_inner().id, id, "update id mismatch for {{ entity_snake }}");
    }

    #[rstest]
    #[tokio::test]
    async fn delete(#[future] grpc_addr: String) {
        let addr = grpc_addr.await;
        let created = setup_grpc_{{ entity_snake }}(&addr).await;
        let id = created.id.clone();
        let mut client = {{ entity_pascal }}ServiceClient::connect(addr)
            .await.expect("connect");
        client
            .delete(tonic::Request::new(e2e::proto::Delete{{ entity_pascal }}Request { id: id.clone() }))
            .await
            .expect("grpc delete {{ entity_snake }}");
        // Verify get now returns not-found
        let result = client
            .get(tonic::Request::new(e2e::proto::Get{{ entity_pascal }}Request { id }))
            .await;
        assert!(result.is_err(), "Expected gRPC not-found after delete of {{ entity_snake }}");
    }
}

