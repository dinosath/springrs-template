// ============================================================================
// Authentication tests
// ============================================================================

/// Lazily generates and caches a unique password for this test run.
/// Using a timestamp-based value avoids hardcoded secrets in the binary.
static TEST_PASSWORD: std::sync::OnceLock<String> = std::sync::OnceLock::new();

fn test_password() -> &'static str {
    TEST_PASSWORD.get_or_init(|| {
        use std::time::{SystemTime, UNIX_EPOCH};
        let ms = SystemTime::now()
            .duration_since(UNIX_EPOCH)
            .unwrap_or_default()
            .as_millis();
        format!("Tp{ms}A!")
    })
}

mod auth {
    use super::*;
    use e2e::{base_url, http_client};
    use rstest::rstest;

    #[rstest]
    #[tokio::test]
    async fn register_returns_token(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let resp = http_client
            .post(format!("{}/api/auth/register", base_url))
            .json(&serde_json::json!({"username": "reg_test_user", "password": test_password()}))
            .send().await.expect("POST /api/auth/register failed");
        assert!(resp.status().is_success(), "register failed: {}", resp.status());
        let body: Value = resp.json().await.expect("parse register body");
        assert!(body["token"].is_string(), "expected token in register response: {:?}", body);
    }

    #[rstest]
    #[tokio::test]
    async fn login_returns_token(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        // Ensure user exists first.
        let _ = http_client
            .post(format!("{}/api/auth/register", base_url))
            .json(&serde_json::json!({"username": "login_test_user", "password": test_password()}))
            .send().await;
        let resp = http_client
            .post(format!("{}/api/auth/login", base_url))
            .json(&serde_json::json!({"username": "login_test_user", "password": test_password()}))
            .send().await.expect("POST /api/auth/login failed");
        assert!(resp.status().is_success(), "login failed: {}", resp.status());
        let body: Value = resp.json().await.expect("parse login body");
        assert!(body["token"].is_string(), "expected token in login response: {:?}", body);
    }

    #[rstest]
    #[tokio::test]
    async fn login_wrong_password_is_rejected(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let _ = http_client
            .post(format!("{}/api/auth/register", base_url))
            .json(&serde_json::json!({"username": "wrong_pw_user", "password": test_password()}))
            .send().await;
        let resp = http_client
            .post(format!("{}/api/auth/login", base_url))
            .json(&serde_json::json!({"username": "wrong_pw_user", "password": "WrongPassword!"}))
            .send().await.expect("POST /api/auth/login failed");
        assert_eq!(resp.status().as_u16(), 401, "expected 401 for wrong password");
    }

    #[rstest]
    #[tokio::test]
    async fn me_returns_user_info(
        #[future] base_url: String,
        http_client: reqwest::Client,
    ) {
        let base_url = base_url.await;
        // Register + login to get a token.
        let _ = http_client
            .post(format!("{}/api/auth/register", base_url))
            .json(&serde_json::json!({"username": "me_test_user", "password": test_password()}))
            .send().await;
        let login_resp: Value = http_client
            .post(format!("{}/api/auth/login", base_url))
            .json(&serde_json::json!({"username": "me_test_user", "password": test_password()}))
            .send().await.expect("login failed").json().await.expect("parse login");
        let token = login_resp["token"].as_str().expect("token missing");

        let me_resp = http_client
            .get(format!("{}/api/auth/me", base_url))
            .header("Authorization", format!("Bearer {token}"))
            .send().await.expect("GET /api/auth/me failed");
        assert!(me_resp.status().is_success(), "me failed: {}", me_resp.status());
        let me_body: Value = me_resp.json().await.expect("parse me body");
        assert_eq!(me_body["user_id"].as_str().unwrap_or(""), "me_test_user");
    }

    #[rstest]
    #[tokio::test]
    async fn protected_endpoint_requires_auth(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        // A request without Authorization header to a protected entity endpoint must be rejected.
        let resp = http_client
            .get(format!("{}/api/health", base_url)) // health is always public
            .send().await.expect("health check failed");
        assert!(resp.status().is_success(), "health check should always succeed");

        // Pick the first entity endpoint from the schema to verify auth is enforced.
        // We use a known path that can't exist (id=0) so we only get auth errors, not 404 races.
        {% for en, e in entities | items | selectattr("1.attributes") %}{% if loop.first %}
        let protected_resp = http_client
            .get(format!("{}/api/{{ e.info.pluralName | kebab_case }}/0", base_url))
            .send().await.expect("request failed");
        assert_eq!(
            protected_resp.status().as_u16(), 401,
            "expected 401 without auth token on protected endpoint"
        );
        {% endif %}{% endfor %}
    }

    #[rstest]
    #[tokio::test]
    async fn me_without_token_is_rejected(#[future] base_url: String, http_client: reqwest::Client) {
        let base_url = base_url.await;
        let resp = http_client
            .get(format!("{}/api/auth/me", base_url))
            .send().await.expect("GET /api/auth/me failed");
        assert_eq!(resp.status().as_u16(), 401, "expected 401 without auth token");
    }
}
