{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_snake = entity_name | snake_case -%}
{% set entity_plural = entity.info.pluralName | kebab_case -%}
async fn setup_{{ entity_snake }}(base_url: &str, client: &reqwest::Client) -> Value {
    {% for attr_name, attr_prop in entity.attributes | items -%}
    {% if macros.relation_is_many_to_one(attr_prop) == 'true' or (macros.relation_is_one_to_one(attr_prop) == 'true' and not attr_prop.mappedBy) -%}
    let {{ attr_name | snake_case }}_dep = setup_{{ attr_prop.target | snake_case }}(base_url, client).await;
    let {{ attr_name | snake_case }}_id = extract_id(&{{ attr_name | snake_case }}_dep);
    {% endif -%}
    {% endfor -%}
    let body = json!({
        {% for attr_name, attr_prop in entity.attributes | items -%}
        {% if attr_prop.type == 'relation' -%}
            {% if macros.relation_is_many_to_one(attr_prop) == 'true' or (macros.relation_is_one_to_one(attr_prop) == 'true' and not attr_prop.mappedBy) -%}
        "{{ attr_name | snake_case }}_id": {{ attr_name | snake_case }}_id,
            {% endif -%}
        {% elif attr_name == 'created_at' or attr_name == 'last_updated' -%}
        {# auto-managed – skip #}
        {% elif attr_prop.enum -%}
        "{{ attr_name | snake_case }}": "{{ attr_prop.enum[0] }}",
        {% elif attr_prop.type == 'string' -%}
            {% if attr_prop.format == 'email' -%}
        "{{ attr_name | snake_case }}": "test_{{ entity_snake }}@example.com",
            {% elif attr_prop.format == 'url' or attr_prop.format == 'uri' -%}
        "{{ attr_name | snake_case }}": "https://example.com/{{ entity_snake }}",
            {% elif attr_prop.format == 'date-time' or attr_prop.format == 'date' -%}
        {# datetime – only set if required #}
            {% if attr_prop.required -%}
        "{{ attr_name | snake_case }}": "2024-01-01T00:00:00",
            {% endif -%}
            {% else -%}
        "{{ attr_name | snake_case }}": "test_{{ entity_snake }}_{{ attr_name | snake_case }}",
            {% endif -%}
        {% elif attr_prop.type == 'text' -%}
        "{{ attr_name | snake_case }}": "test {{ entity_snake }} {{ attr_name | snake_case }} content",
        {% elif attr_prop.type == 'integer' -%}
        "{{ attr_name | snake_case }}": {{ attr_prop.default | default(1) }},
        {% elif attr_prop.type == 'number' -%}
        "{{ attr_name | snake_case }}": 1.0,
        {% elif attr_prop.type == 'boolean' -%}
        "{{ attr_name | snake_case }}": {{ attr_prop.default | default(true) | lower }},
        {% endif -%}
        {% endfor -%}
    });
    api_post(client, &format!("{}/api/{{ entity_plural }}", base_url), &body).await
}

