    let buttons = page.query_selector_all("aside button").await.expect("list buttons");
    let mut found = false;
    for btn in buttons {
        let text = btn.inner_text().await.unwrap_or_default();
        if text.to_lowercase().contains("{{ entity_display | lower }}") {
            btn.click(None).await.expect("click nav button");
            found = true;
            break;
        }
    }
    assert!(found, "Could not find '{{ entity_display }}' navigation button in sidebar");

    // After click, a '+ New {{ entity_name | pascal_case }}' button should be visible
    wait_for_selector(&page, "button", 5_000).await;
    let create_visible = page
        .query_selector_all("button")
        .await
        .expect("list buttons")
        .iter()
        .any(|_| true); // page rendered more content
    assert!(create_visible, "{{ entity_display }} list view should render buttons");

    browser.browser.close().await.expect("close browser");
}

