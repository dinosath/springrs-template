//! Integration test infrastructure
//!
//! Shared test server initialization, container lifecycle, and auth helpers
//! used by all protocol-specific test modules.

use axum_test::TestServer;
use serde_json::json;
{% if database == 'postgres' -%}
use testcontainers::ContainerAsync;
{% if authentication == 'keycloak' -%}
use testcontainers::{GenericImage, ImageExt};
{% endif -%}
use testcontainers_modules::{postgres::Postgres, testcontainers::runners::AsyncRunner};
{% endif -%}
{% if authentication == 'keycloak' or authentication == 'jwt' -%}
use std::collections::HashMap;
{% endif -%}
use tokio::sync::OnceCell;
use {{ project_name | snake_case }}::create_app;

static TEST_SERVER: OnceCell<TestServer> = OnceCell::const_new();
{% if database == 'postgres' -%}
static DB_CONTAINER: OnceCell<ContainerAsync<Postgres>> = OnceCell::const_new();
{% endif -%}
{% if authentication == 'keycloak' -%}
static KEYCLOAK_CONTAINER: OnceCell<ContainerAsync<GenericImage>> = OnceCell::const_new();
static AUTH_TOKEN: OnceCell<String> = OnceCell::const_new();
{% elif authentication == 'jwt' -%}
static AUTH_TOKEN: OnceCell<String> = OnceCell::const_new();
{% endif -%}

/// Lazily generates and caches a unique password for this test run so that no
/// hardcoded credentials appear in the compiled binary or its output.
static TEST_PASSWORD: std::sync::OnceLock<String> = std::sync::OnceLock::new();

fn test_password() -> &'static str {
    TEST_PASSWORD.get_or_init(|| {
        use std::time::{SystemTime, UNIX_EPOCH};
        let ms = SystemTime::now()
            .duration_since(UNIX_EPOCH)
            .unwrap_or_default()
            .as_millis();
        format!("Tp{ms}A!")
    })
}

/// Initialize the test server with all dependencies
async fn init_test_server() -> &'static TestServer {
    TEST_SERVER
        .get_or_init(|| async {
{% if database == 'postgres' -%}
            // Start database container
            let db_container = DB_CONTAINER
                .get_or_init(|| async {
                    Postgres::default()
                        .start()
                        .await
                        .expect("Failed to start Postgres container")
                })
                .await;

            let db_port = db_container
                .get_host_port_ipv4(5432)
                .await
                .expect("Failed to get database port");

            let database_url = format!(
                "postgres://postgres:postgres@127.0.0.1:{}/postgres",
                db_port
            );

            std::env::set_var("DATABASE_URL", &database_url);
{% endif -%}

{% if authentication == 'keycloak' -%}
            // Start Keycloak container
            let keycloak_container = KEYCLOAK_CONTAINER
                .get_or_init(|| async {
                    GenericImage::new("quay.io/keycloak/keycloak", "latest")
                        .with_env_var("KEYCLOAK_ADMIN", "admin")
                        .with_env_var("KEYCLOAK_ADMIN_PASSWORD", "admin")
                        .with_exposed_port(8080)
                        .with_wait_for(testcontainers::core::WaitFor::message_on_stdout(
                            "Keycloak",
                        ))
                        .start()
                        .await
                        .expect("Failed to start Keycloak container")
                })
                .await;

            let keycloak_port = keycloak_container
                .get_host_port_ipv4(8080)
                .await
                .expect("Failed to get Keycloak port");

            let keycloak_url = format!("http://127.0.0.1:{}", keycloak_port);
            std::env::set_var("KEYCLOAK_URL", &keycloak_url);
{% endif -%}

            // Create the app
            let app = create_app()
                .await
                .expect("Failed to create app");

            // Create test server
            TestServer::new(app).expect("Failed to create test server")
        })
        .await
}

{% if authentication == 'jwt' -%}
/// Get or create an authentication token.
async fn get_auth_token(server: &TestServer) -> &'static str {
    AUTH_TOKEN
        .get_or_init(|| async {
            let response = server
                .post("/api/auth/register")
                .json(&json!({
                    "username": "testuser",
                    "password": test_password()
                }))
                .await;

            if response.status_code().is_success() {
                response
                    .json::<serde_json::Value>()["token"]
                    .as_str()
                    .unwrap_or_default()
                    .to_string()
            } else {
                // User already exists – fall back to login.
                server
                    .post("/api/auth/login")
                    .json(&json!({
                        "username": "testuser",
                        "password": test_password()
                    }))
                    .await
                    .json::<serde_json::Value>()["token"]
                    .as_str()
                    .unwrap_or_default()
                    .to_string()
            }
        })
        .await
}

/// Tests for the authentication endpoints.
#[cfg(test)]
mod auth_tests {
    use super::*;

    #[tokio::test]
    async fn test_register_returns_token() {
        let server = init_test_server().await;
        let response = server
            .post("/api/auth/register")
            .json(&json!({"username": "auth_reg_user", "password": test_password()}))
            .await;
        assert!(
            response.status_code().is_success(),
            "register failed: {} – {:?}",
            response.status_code(),
            response.text()
        );
        let body: serde_json::Value = response.json();
        assert!(
            body["token"].is_string(),
            "expected 'token' string in register response, got: {:?}",
            body
        );
    }

    #[tokio::test]
    async fn test_login_returns_token() {
        let server = init_test_server().await;
        // Ensure the user exists.
        let _ = server
            .post("/api/auth/register")
            .json(&json!({"username": "auth_login_user", "password": test_password()}))
            .await;
        let response = server
            .post("/api/auth/login")
            .json(&json!({"username": "auth_login_user", "password": test_password()}))
            .await;
        assert!(
            response.status_code().is_success(),
            "login failed: {} – {:?}",
            response.status_code(),
            response.text()
        );
        let body: serde_json::Value = response.json();
        assert!(body["token"].is_string(), "expected 'token' in login response, got: {:?}", body);
    }

    #[tokio::test]
    async fn test_login_wrong_password_rejected() {
        let server = init_test_server().await;
        let _ = server
            .post("/api/auth/register")
            .json(&json!({"username": "auth_bad_pw_user", "password": test_password()}))
            .await;
        let response = server
            .post("/api/auth/login")
            .json(&json!({"username": "auth_bad_pw_user", "password": "WrongPassword!"}))
            .await;
        assert_eq!(
            response.status_code().as_u16(), 401,
            "expected 401 for wrong password, got: {}",
            response.status_code()
        );
    }

    #[tokio::test]
    async fn test_me_returns_user_info() {
        let server = init_test_server().await;
        let token = get_auth_token(server).await;
        let response = server
            .get("/api/auth/me")
            .add_header(
                "Authorization".parse().unwrap(),
                format!("Bearer {token}").parse().unwrap(),
            )
            .await;
        assert!(
            response.status_code().is_success(),
            "/api/auth/me failed: {} – {:?}",
            response.status_code(),
            response.text()
        );
        let body: serde_json::Value = response.json();
        assert!(
            body["user_id"].is_string(),
            "expected 'user_id' in /api/auth/me response, got: {:?}",
            body
        );
    }

    #[tokio::test]
    async fn test_me_without_token_rejected() {
        let server = init_test_server().await;
        let response = server.get("/api/auth/me").await;
        assert_eq!(
            response.status_code().as_u16(), 401,
            "expected 401 without auth token, got: {}",
            response.status_code()
        );
    }

    #[tokio::test]
    async fn test_logout_succeeds() {
        let server = init_test_server().await;
        let response = server.post("/api/auth/logout").await;
        assert!(
            response.status_code().is_success(),
            "logout failed: {}",
            response.status_code()
        );
    }
}
{% elif authentication == 'keycloak' -%}
/// Get or create an authentication token
async fn get_auth_token(_server: &TestServer) -> &'static str {
    AUTH_TOKEN
        .get_or_init(|| async {
            let keycloak_url = std::env::var("KEYCLOAK_URL")
                .expect("KEYCLOAK_URL must be set");
            
            let client = reqwest::Client::new();
            let response = client
                .post(format!("{}/realms/master/protocol/openid-connect/token", keycloak_url))
                .form(&[
                    ("client_id", "admin-cli"),
                    ("username", "admin"),
                    ("password", "admin"),
                    ("grant_type", "password"),
                ])
                .send()
                .await
                .expect("Failed to get token");

            let token_response: serde_json::Value = response
                .json()
                .await
                .expect("Failed to parse token response");

            token_response["access_token"]
                .as_str()
                .unwrap()
                .to_string()
        })
        .await
}
