{% import "macros.jinja" as macros -%}
{% import "rust/types.jinja" as rust_types -%}
{% set model = entity_name | pascal_case -%}
use spring_web::{get, post, put, delete};
use spring_web::{
    error::Result,
    extractor::{Path, Component, Json},
    axum::{http::{HeaderMap, HeaderValue, StatusCode}, response::IntoResponse},
};
use sea_orm::{ActiveModelTrait, ModelTrait, EntityTrait, ConnectionTrait};
use sea_orm::EntityLoaderTrait;
use spring_sea_orm::DbConn;
use spring::tracing::debug;
use crate::models::{{ rust_types.identifier(entity_name) }}::{ActiveModel, Entity, Model, {{model}}Create,{{model}}Update,{{model}}Response};
/**
{% if entity.attributes | items | selectattr('1.type','equalto','relation') | length > 0 -%}
use super::{ {%- for rel in macros.get_all_relations(entity)|split(',') %}{{ rust_types.identifier(rel| trim | snake_case)  }}::{{rel | pascal_case}} as {{ rel | trim | pascal_case}}{% if not loop.last %}, {% endif -%}{% endfor -%} };
{% endif -%}
**/
async fn load_item<C>(
    db: &C,
    id: i32,
) -> Result<Model>
where
    C: ConnectionTrait,
{
    debug!("Loading {{ entity_name | snake_case }} with id: {}", id);
    Entity::find_by_id(id)
        .one(db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| spring_web::error::KnownWebError::not_found("not found").into())
}

#[get("/api/{{ entity.info.pluralName | kebab_case }}")]
pub async fn list(Component(db): Component<DbConn>) -> Result<impl IntoResponse> {
    debug!("Fetching list of {{ entity.info.pluralName | kebab_case }}");
    let models = Entity::load()
        {% for name, property in entity.attributes | items -%}
        {%- if macros.is_relation(property)=='true' -%}
        .with(crate::models::{{ rust_types.identifier(macros.get_relation(property)) }}::Entity)
        {% endif -%}
        {% endfor -%}
        .all(&db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    debug!("Loaded {} {{ entity.info.pluralName | kebab_case }}", models.len());
    let responses: Vec<{{ entity_name | pascal_case }}Response> = models.into_iter().map(Into::into).collect();

    let total = responses.len() as u64;
    let start: u64 = 0;
    let end: u64 = if total == 0 { 0 } else { total - 1 };
    let mut headers = HeaderMap::new();
    let content_range_value = format!("items {}-{}/{}", start, end, total);
    headers.insert("Content-Range", HeaderValue::from_str(&content_range_value).unwrap());
    headers.insert("Accept-Ranges", HeaderValue::from_static("items"));
    Ok((StatusCode::OK, headers, Json(responses)))
}

#[post("/api/{{ entity.info.pluralName | kebab_case }}")]
pub async fn create(Component(db): Component<DbConn>, Json(create): Json<{{model}}Create>) -> Result<impl IntoResponse> {
    debug!("Creating new {{ entity_name | snake_case }} - Request: {:?}",create);
    let active_model: ActiveModel = create.into();
    let model = active_model.insert(&db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(format!("failed to insert item: {}", e)))?
        .into_ex();
    debug!("Created {{ entity_name | snake_case }} with id: {:?}", model.id);
    let resp: {{model}}Response = model.into();
    Ok((StatusCode::CREATED, Json(resp)))
}

#[put("/api/{{ entity.info.pluralName | kebab_case }}/{id}")]
pub async fn update(Component(db): Component<DbConn>, Path(id): Path<i32>, Json(update): Json<{{model}}Update>) -> Result<impl IntoResponse> {
    debug!("Updating {{ entity_name | snake_case }} with id: {}", id);
    let existing_active_model = load_item(&db, id).await?;
    let active_model = update.merge_into(existing_active_model.into()).expect("Failed to merge");
    let model = active_model.update(&db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(format!("failed to update item: {}", e)))?
        .into_ex();
    debug!("Successfully updated {{ entity_name | snake_case }} with id: {}", id);
    let resp: {{model}}Response = model.into();
    Ok(Json(resp))
}

#[delete("/api/{{ entity.info.pluralName | kebab_case }}/{id}")]
pub async fn remove(Component(db): Component<DbConn>, Path(id): Path<i32>) -> Result<impl IntoResponse> {
    debug!("Deleting {{ entity_name | snake_case }} with id: {}", id);
    let model = load_item(&db, id).await?;
    model.delete(&db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    debug!("Successfully deleted {{ entity_name | snake_case }} with id: {}", id);
    Ok(StatusCode::NO_CONTENT)
}

#[get("/api/{{ entity.info.pluralName | kebab_case }}/{id}")]
pub async fn read_one(Component(db): Component<DbConn>, Path(id): Path<i32>) -> Result<impl IntoResponse> {
    debug!("Fetching {{ entity_name | snake_case }} with id: {}", id);
    let model = Entity::load()
        .filter_by_id(id)
        {% for name, property in entity.attributes | items -%}
        {%- if macros.is_relation(property)=='true' -%}
        {% if 'models' in extra_crates -%}
        .with(models::{{ rust_types.identifier(macros.get_relation(property)) }}::Entity)
        {% else -%}
        .with(crate::models::{{ rust_types.identifier(macros.get_relation(property)) }}::Entity)
        {% endif -%}
        {% endif -%}
        {% endfor -%}
        .one(&db)
        .await
        .map_err(|e| spring_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| spring_web::error::KnownWebError::not_found("not found"))?;
    debug!("Successfully fetched {{ entity_name | snake_case }} with id: {}", id);
    let resp: {{model}}Response = model.into();
    Ok(Json(resp))
}
