/// Build the fully-initialised axum [`Router`] without binding a TCP listener.
///
/// Runs every registered plugin's `build()` hook (database connection, auth, …)
/// and extracts the composed router, ready for [`axum_test::TestServer`].
pub async fn create_app() -> anyhow::Result<summer_web::axum::Router> {
    use std::ops::Deref;
    use std::sync::Arc;
    use summer::App;
    use summer::plugin::ComponentRegistry;
    {{ 'use summer_sea_orm::SeaOrmPlugin;' if database != 'none' and orm == 'seaorm' }}
    use summer_web::{AppState, RouterLayers, WebConfigurator, WebPlugin};
    use summer_web::axum::http::HeaderValue;
    {{ 'use crate::services::seaorm_migration_plugin::SeaOrmMigrationPlugin;' if use_seaorm_migrations }}
    {% if authentication == 'jwt' -%}
    use crate::services::auth_plugin::AuthPlugin;
    {% endif -%}
    {% if row_level_security -%}
    use crate::services::tenant_plugin::TenantPlugin;
    {% endif -%}

    let app: Arc<summer::App> = App::new()
        .add_router(::summer_web::handler::auto_router())
        {{ '.add_plugin(SeaOrmPlugin)' if database != 'none' and orm == 'seaorm' }}
        {{ '.add_plugin(AuthPlugin)' if authentication == 'jwt' }}
        {{ '.add_plugin(TenantPlugin)' if row_level_security }}
        {{ '.add_plugin(SeaOrmMigrationPlugin)' if use_seaorm_migrations }}
        .add_plugin(WebPlugin)
        .build()
        .await?;

    let mut router = app
        .get_component::<summer_web::Router>()
        .expect("Router not found – ensure WebPlugin was added");

    if let Some(layers) = app.get_component_ref::<RouterLayers>() {
        let layers: summer_web::RouterLayers = layers.deref().clone();
        for layer_fn in layers.iter() {
            router = layer_fn(router);
        }
    }

    // ─── Security headers (always applied) ──────────────────────────────
    use summer_web::axum::http::header;
    use tower_http::set_header::SetResponseHeaderLayer;

    router = router
        .layer(SetResponseHeaderLayer::overriding(
            header::X_CONTENT_TYPE_OPTIONS,
            HeaderValue::from_static("nosniff"),
        ))
        .layer(SetResponseHeaderLayer::overriding(
            header::X_FRAME_OPTIONS,
            HeaderValue::from_static("DENY"),
        ))
        .layer(SetResponseHeaderLayer::overriding(
            header::HeaderName::from_static("x-xss-protection"),
            HeaderValue::from_static("1; mode=block"),
        ))
        .layer(SetResponseHeaderLayer::overriding(
            header::HeaderName::from_static("x-download-options"),
            HeaderValue::from_static("noopen"),
        ))
        .layer(SetResponseHeaderLayer::overriding(
            header::HeaderName::from_static("referrer-policy"),
            HeaderValue::from_static("strict-origin-when-cross-origin"),
        ));
{% if security_level | default('standard') == 'hardened' %}
    // ─── Hardened: request body size limit ───────────────────────────────
    router = router.layer(tower_http::limit::RequestBodyLimitLayer::new(2 * 1024 * 1024)); // 2 MB

    // ─── Hardened: CORS strict origin ────────────────────────────────────
    use tower_http::cors::{CorsLayer, AllowOrigin};
    let cors = CorsLayer::new()
        .allow_origin(AllowOrigin::list(
            std::env::var("CORS_ORIGINS")
                .unwrap_or_default()
                .split(',')
                .filter(|s| !s.is_empty())
                .filter_map(|s| s.parse::<HeaderValue>().ok())
                .collect::<Vec<_>>(),
        ))
        .allow_methods([
            axum::http::Method::GET,
            axum::http::Method::POST,
            axum::http::Method::PUT,
            axum::http::Method::DELETE,
            axum::http::Method::OPTIONS,
        ])
        .allow_headers([header::CONTENT_TYPE, header::AUTHORIZATION, header::HeaderName::from_static("x-tenant-id")])
        .max_age(std::time::Duration::from_secs(3600));
    router = router.layer(cors);
{% endif %}

    Ok(router.layer(summer_web::axum::Extension(AppState { app })))
}
{% endif -%}
