}

#[post("/api/{{ entity.info.pluralName | kebab_case }}/batch")]
pub async fn batch_create(Component(db): Component<DbConn>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}, Json(items): Json<Vec<{{model}}Create>>) -> Result<impl IntoResponse> {
    if items.len() > MAX_BATCH_SIZE {
        return Err(summer_web::error::KnownWebError::bad_request(
            format!("batch size {} exceeds maximum of {}", items.len(), MAX_BATCH_SIZE)
        ).into());
    }
    debug!("Batch creating {} {{ entity.info.pluralName | kebab_case }}", items.len());
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% if entity_rls -%}
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% endif -%}
    let mut responses = Vec::with_capacity(items.len());
    for item in items {
        {% if entity_rls -%}
        let mut item = item;
        item.tenant_id = tenant.as_str().to_owned();
        {% endif -%}
        let active_model = item.into_active_model();
        let model = active_model.insert(&txn).await
            .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to insert item: {}", e)))?;
        responses.push({{model}}Response::from(model));
    }
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    debug!("Batch created {} {{ entity.info.pluralName | kebab_case }}", responses.len());
    Ok((StatusCode::CREATED, Json(responses)))
}

#[put("/api/{{ entity.info.pluralName | kebab_case }}/batch")]
pub async fn batch_update(Component(db): Component<DbConn>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}, Json(items): Json<Vec<{{model}}BatchUpdateItem>>) -> Result<impl IntoResponse> {
    if items.len() > MAX_BATCH_SIZE {
        return Err(summer_web::error::KnownWebError::bad_request(
            format!("batch size {} exceeds maximum of {}", items.len(), MAX_BATCH_SIZE)
        ).into());
    }
    debug!("Batch updating {} {{ entity.info.pluralName | kebab_case }}", items.len());
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% if entity_rls -%}
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% endif -%}
    let mut responses = Vec::with_capacity(items.len());
    for item in items {
        let _ = load_item(&txn, item.id).await?;
        let mut active_model = item.data.into_active_model();
        active_model.id = Set(item.id);
        let model = active_model.update(&txn).await
            .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to update item: {}", e)))?;
        responses.push({{model}}Response::from(model));
    }
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    debug!("Batch updated {} {{ entity.info.pluralName | kebab_case }}", responses.len());
    Ok(Json(responses))
}

#[delete("/api/{{ entity.info.pluralName | kebab_case }}/batch")]
pub async fn batch_delete(Component(db): Component<DbConn>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}, Json(ids): Json<Vec<i32>>) -> Result<impl IntoResponse> {
    if ids.len() > MAX_BATCH_SIZE {
        return Err(summer_web::error::KnownWebError::bad_request(
            format!("batch size {} exceeds maximum of {}", ids.len(), MAX_BATCH_SIZE)
        ).into());
    }
    debug!("Batch deleting {} {{ entity.info.pluralName | kebab_case }}", ids.len());
    {% if entity_rls -%}
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    Entity::delete_many()
        .filter(Column::Id.is_in(ids))
        .exec(&txn)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% else -%}
    Entity::delete_many()
        .filter(Column::Id.is_in(ids))
        .exec(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% endif -%}
    debug!("Batch delete completed for {{ entity.info.pluralName | kebab_case }}");
    Ok(StatusCode::NO_CONTENT)
}
