/// Maximum number of items per page (hard cap).
const MAX_PAGE_SIZE: u64 = 100;
/// Maximum number of items allowed in batch operations.
const MAX_BATCH_SIZE: usize = 100;

/// Pagination query parameters for list endpoints.
#[derive(Debug, Deserialize)]
pub struct ListParams {
    /// Page number (1-indexed, default: 1).
    #[serde(default = "default_page")]
    pub page: u64,
    /// Items per page (default: 25, max: 100).
    #[serde(default = "default_page_size")]
    pub page_size: u64,
}
fn default_page() -> u64 { 1 }
fn default_page_size() -> u64 { 25 }

async fn load_item<C>(
    db: &C,
    id: i32,
) -> Result<Model>
where
    C: ConnectionTrait,
{
    debug!("Loading {{ entity_name | snake_case }} with id: {}", id);
    Entity::find_by_id(id)
        .one(db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| summer_web::error::KnownWebError::not_found("not found").into())
}

#[get("/api/{{ entity.info.pluralName | kebab_case }}")]
pub async fn list(Component(db): Component<DbConn>, Query(params): Query<ListParams>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}) -> Result<impl IntoResponse> {
    debug!("Fetching list of {{ entity.info.pluralName | kebab_case }}");
    let page_size = params.page_size.min(MAX_PAGE_SIZE);
    let page = params.page.max(1);
    let offset = (page.saturating_sub(1)) * page_size;
    {% if entity_rls -%}
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    let total = Entity::find().count(&txn).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    let models = Entity::find()
        .limit(page_size)
        .offset(offset)
        .all(&txn)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% else -%}
    let total = Entity::find().count(&db).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    let models = Entity::find()
        .limit(page_size)
        .offset(offset)
        .all(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% endif -%}
    debug!("Loaded {} {{ entity.info.pluralName | kebab_case }}", models.len());
    let responses: Vec<{{ entity_name | pascal_case }}Response> = models.into_iter().map(Into::into).collect();

    let count = responses.len() as u64;
    let start: u64 = offset;
    let end: u64 = if count == 0 { start } else { start + count - 1 };
    let mut headers = HeaderMap::new();
    let content_range_value = format!("items {}-{}/{}", start, end, total);
    if let Ok(val) = HeaderValue::from_str(&content_range_value) {
        headers.insert("Content-Range", val);
    }
    headers.insert("Accept-Ranges", HeaderValue::from_static("items"));
    Ok((StatusCode::OK, headers, Json(responses)))
}

#[post("/api/{{ entity.info.pluralName | kebab_case }}")]
pub async fn create(Component(db): Component<DbConn>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}, Json(create): Json<{{model}}Create>) -> Result<impl IntoResponse> {
    create.validate()
        .map_err(|e| summer_web::error::KnownWebError::bad_request(e.to_string()))?;
    debug!("Creating new {{ entity_name | snake_case }} - Request: {:?}",create);
    {% if entity_rls -%}
    let mut create = create;
    create.tenant_id = tenant.as_str().to_owned();
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    let active_model = create.into_active_model();
    let model = active_model.insert(&txn)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to insert item: {}", e)))?;
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% else -%}
    let active_model = create.into_active_model();
    let model = active_model.insert(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to insert item: {}", e)))?;
    {% endif -%}
    debug!("Created {{ entity_name | snake_case }} with id: {:?}", model.id);
    let resp: {{model}}Response = model.into();
    Ok((StatusCode::CREATED, Json(resp)))
}

#[put("/api/{{ entity.info.pluralName | kebab_case }}/{id}")]
pub async fn update(Component(db): Component<DbConn>, Path(id): Path<i32>{% if authentication == 'jwt' %}, _auth: AuthUser{% endif %}{% if entity_rls %}, tenant: TenantId{% endif %}, Json(update): Json<{{model}}Update>) -> Result<impl IntoResponse> {
    update.validate()
        .map_err(|e| summer_web::error::KnownWebError::bad_request(e.to_string()))?;
    debug!("Updating {{ entity_name | snake_case }} with id: {}", id);
    {% if entity_rls -%}
    let txn = db.begin().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    set_tenant(&txn, &tenant).await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    let _ = load_item(&txn, id).await?;
    let mut active_model = update.into_active_model();
    active_model.id = Set(id);
    let model = active_model.update(&txn)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to update item: {}", e)))?;
    txn.commit().await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;
    {% else -%}
    let _ = load_item(&db, id).await?;
    let mut active_model = update.into_active_model();
    active_model.id = Set(id);
    let model = active_model.update(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(format!("failed to update item: {}", e)))?;
    {% endif -%}
    debug!("Successfully updated {{ entity_name | snake_case }} with id: {}", id);
    let resp: {{model}}Response = model.into();
    Ok(Json(resp))
}

