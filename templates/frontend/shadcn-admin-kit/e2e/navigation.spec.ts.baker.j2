{% import "macros.jinja" as macros -%}
import { test, expect } from '@playwright/test';

{% if authentication == 'jwt' or authentication == 'oidc' %}
// Helper: login before navigation tests
async function login(page: import('@playwright/test').Page) {
  await page.goto('/');
  await page.getByLabel('Email / Username').fill('admin');
  await page.getByLabel('Password').fill('admin');
  await page.getByRole('button', { name: 'Sign in' }).click();
  await page.waitForURL(url => !url.pathname.includes('login'), { timeout: 10000 });
}

test.describe('Navigation', () => {
  test.beforeEach(async ({ page }) => {
    await login(page);
  });

  test('shows sidebar navigation with all resources', async ({ page }) => {
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_plural = entity_name | plural -%}
    await expect(page.getByRole('link', { name: /{{ entity_plural | lower }}/i })).toBeVisible({ timeout: 10000 });
{% endfor %}
  });

{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_plural = entity_name | plural | snake_case -%}
{% set first_field = entity.attributes | items | selectattr("1.type", "equalto", "string") | list | first %}
  test('navigates to {{ entity_plural }} list', async ({ page }) => {
    await page.getByRole('link', { name: /{{ entity_plural | lower }}/i }).click();
    await expect(page).toHaveURL(/\/{{ entity_plural }}/);
    await expect(page.getByText('{{ first_field[1].example | default(first_field[0] | title | replace("_", " ") ~ " 1") }}')).toBeVisible({ timeout: 10000 });
  });

{% endfor %}
});
{% else %}
test.describe('Navigation', () => {
  test('shows navigation', async ({ page }) => {
    await page.goto('/');
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_plural = entity_name | plural -%}
    await expect(page.getByRole('link', { name: /{{ entity_plural | lower }}/i })).toBeVisible({ timeout: 10000 });
{% endfor %}
  });
});
{% endif %}
