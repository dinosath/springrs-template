{% import "macros.jinja" as macros -%}
import { describe, it, expect } from 'vitest';
import { handlers } from './mocks/handlers';

describe('MSW handlers', () => {
  it('exports a non-empty handlers array', () => {
    expect(handlers).toBeInstanceOf(Array);
    expect(handlers.length).toBeGreaterThan(0);
  });

  it('has handlers for all resource endpoints', () => {
    const resources = [
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% set entity_plural = entity_name | plural | snake_case -%}
      '{{ entity_plural }}',
{% endfor %}
    ];
    const handlerPaths = handlers.map((h) => (h as { info: { path: string } }).info.path as string);
    for (const resource of resources) {
      const hasGet = handlerPaths.some((p) => p.includes(`/api/${resource}`));
      expect(hasGet, `Expected handler for /api/${resource}`).toBe(true);
    }
  });

{% if authentication == 'jwt' or authentication == 'oidc' %}
  it('has auth handlers', () => {
    const handlerPaths = handlers.map((h) => (h as { info: { path: string } }).info.path as string);
    expect(handlerPaths.some((p) => p.includes('/api/auth/login'))).toBe(true);
    expect(handlerPaths.some((p) => p.includes('/api/auth/register'))).toBe(true);
    expect(handlerPaths.some((p) => p.includes('/api/auth/me'))).toBe(true);
  });
{% endif %}
});
