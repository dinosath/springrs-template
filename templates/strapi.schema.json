{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Strapi v5 Content Types Schema",
    "description": "A map of Strapi v5 content-types keyed by content-type name (e.g., BlogPost, UserProfile). Each value follows Strapi's schema.json structure.",
    "type": "object",

    "patternProperties": {
        "^[A-Za-z][A-Za-z0-9_-]*$": {
            "type": "object",
            "description": "Strapi v5 content-type definition (schema.json format).",
            "required": ["kind", "collectionName", "info", "attributes"],
            "properties": {
                "kind": {
                    "type": "string",
                    "enum": ["collectionType", "singleType"]
                },

                "collectionName": {
                    "type": "string",
                    "description": "Database collection/table name. Usually snake_case plural for collectionType."
                },

                "info": {
                    "type": "object",
                    "required": ["displayName"],
                    "properties": {
                        "displayName": { "type": "string" },
                        "singularName": { "type": "string" },
                        "pluralName": { "type": "string" },
                        "description": { "type": "string" },
                        "icon": { "type": "string" }
                    },
                    "additionalProperties": true
                },

                "options": {
                    "type": "object",
                    "description": "Content-type options; Strapi v5 includes draftAndPublish and may add more in the future.",
                    "properties": {
                        "draftAndPublish": { "type": "boolean" }
                    },
                    "additionalProperties": true
                },

                "pluginOptions": {
                    "type": "object",
                    "description": "Plugin-specific options (e.g., i18n, users-permissions).",
                    "additionalProperties": true
                },

                "priority": {
                    "type": "integer",
                    "default": 0,
                    "description": "Priority for ordering collections."
                },

                "rls": {
                    "type": "boolean",
                    "description": "Override the global row_level_security setting for this entity. When true, a tenant_id column and RLS policy are created."
                },

                "sequence": {
                    "type": "object",
                    "description": "Auto-numbering configuration for a document identifier field. Generates sequential values like INV/2026/00001.",
                    "properties": {
                        "field": {
                            "type": "string",
                            "description": "The attribute name to auto-populate with the generated sequence value."
                        },
                        "prefix": {
                            "type": "string",
                            "description": "Prefix pattern. Supports placeholders: {YYYY} (year), {YY} (2-digit year), {MM} (month), {DD} (day). Example: 'INV/{YYYY}/'."
                        },
                        "suffix": {
                            "type": "string",
                            "description": "Optional suffix pattern. Supports same placeholders as prefix."
                        },
                        "padding": {
                            "type": "integer",
                            "minimum": 1,
                            "description": "Zero-padding width for the numeric portion. E.g., padding=5 produces '00001'."
                        },
                        "startNumber": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1,
                            "description": "Starting number for the sequence counter."
                        },
                        "step": {
                            "type": "integer",
                            "minimum": 1,
                            "default": 1,
                            "description": "Increment step between consecutive numbers."
                        },
                        "resetInterval": {
                            "type": "string",
                            "enum": ["never", "yearly", "monthly", "daily"],
                            "default": "never",
                            "description": "When to reset the counter back to startNumber."
                        }
                    },
                    "required": ["field", "prefix", "padding"]
                },

                "constraints": {
                    "type": "array",
                    "description": "Business validation rules and constraints enforced at the database and/or service layer.",
                    "items": {
                        "type": "object",
                        "required": ["name", "type", "message"],
                        "properties": {
                            "name": {
                                "type": "string",
                                "description": "Unique constraint identifier (snake_case). Used in error codes and SQL object names."
                            },
                            "type": {
                                "type": "string",
                                "enum": ["check", "unique_together", "state_transition", "required_if", "immutable_if"],
                                "description": "Constraint type: 'check' (SQL CHECK or trigger), 'unique_together' (composite unique index), 'state_transition' (trigger-enforced valid state changes), 'required_if' (trigger-enforced conditional NOT NULL), 'immutable_if' (trigger-enforced field immutability)."
                            },
                            "enforcement": {
                                "type": "string",
                                "enum": ["database", "application", "both"],
                                "default": "database",
                                "description": "Where the constraint is enforced. 'database' generates SQL CHECK/triggers, 'application' generates service-layer validation, 'both' generates both."
                            },
                            "message": {
                                "type": "string",
                                "description": "Human-readable error message when the constraint is violated. Used in RAISE EXCEPTION for DB triggers and in API error responses."
                            },
                            "condition": {
                                "type": "string",
                                "description": "SQL-compatible boolean expression for 'check' constraints. Use column names directly. Supports: comparisons (>, <, >=, <=, =, !=), IS NULL, IS NOT NULL, IN (...), AND, OR, NOT. Example: 'quantity > 0'. For cross-row checks, use subquery syntax."
                            },
                            "fields": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "Fields involved in the constraint. For 'unique_together': generates UNIQUE index on these columns. For 'required_if'/'immutable_if': target columns."
                            },
                            "stateField": {
                                "type": "string",
                                "default": "state",
                                "description": "Column name holding the state enum. Used by 'state_transition'. Defaults to 'state'."
                            },
                            "initialStates": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "Valid states on INSERT. Generates: DEFAULT + CHECK constraint ensuring new rows start in one of these states."
                            },
                            "terminalStates": {
                                "type": "array",
                                "items": { "type": "string" },
                                "description": "States from which no further updates to any field are allowed (except by system). Generates a BEFORE UPDATE trigger that rejects changes when in terminal state."
                            },
                            "transitions": {
                                "type": "array",
                                "description": "Valid state transitions. Generates a BEFORE UPDATE trigger function: validates OLD.state -> NEW.state against this list using a VALUES table lookup.",
                                "items": {
                                    "type": "object",
                                    "required": ["from", "to"],
                                    "properties": {
                                        "from": {
                                            "type": "string",
                                            "description": "Source state value (must match enum value exactly)."
                                        },
                                        "to": {
                                            "type": "array",
                                            "items": { "type": "string" },
                                            "description": "Valid target states reachable from the source state."
                                        }
                                    }
                                }
                            },
                            "when": {
                                "type": "string",
                                "description": "SQL boolean expression for 'required_if' and 'immutable_if' triggers. References NEW.column_name. Example: 'NEW.state = ''POSTED'''."
                            }
                        },
                        "allOf": [
                            {
                                "if": { "properties": { "type": { "const": "check" } }, "required": ["type"] },
                                "then": { "required": ["condition"] }
                            },
                            {
                                "if": { "properties": { "type": { "const": "unique_together" } }, "required": ["type"] },
                                "then": { "required": ["fields"] }
                            },
                            {
                                "if": { "properties": { "type": { "const": "state_transition" } }, "required": ["type"] },
                                "then": { "required": ["transitions", "initialStates"] }
                            },
                            {
                                "if": { "properties": { "type": { "const": "required_if" } }, "required": ["type"] },
                                "then": { "required": ["fields", "when"] }
                            },
                            {
                                "if": { "properties": { "type": { "const": "immutable_if" } }, "required": ["type"] },
                                "then": { "required": ["fields", "when"] }
                            }
                        ]
                    }
                },

                "attributes": {
                    "type": "object",
                    "description": "Attribute map keyed by attribute name.",
                    "patternProperties": {
                        "^[a-zA-Z_][a-zA-Z0-9_-]*$": {
                            "type": "object",
                            "required": ["type"],
                            "properties": {
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "string",
                                        "text",
                                        "richtext",
                                        "password",
                                        "email",
                                        "integer",
                                        "biginteger",
                                        "float",
                                        "decimal",
                                        "boolean",
                                        "date",
                                        "datetime",
                                        "time",
                                        "enumeration",
                                        "json",
                                        "uid",
                                        "media",
                                        "relation",
                                        "component",
                                        "dynamiczone"
                                    ]
                                },

                                "required": { "type": "boolean" },
                                "unique": { "type": "boolean" },
                                "private": { "type": "boolean" },
                                "default": {},

                                "minLength": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "maxLength": {
                                    "type": "integer",
                                    "minimum": 0
                                },
                                "regex": { "type": "string" },

                                "min": { "type": "number" },
                                "max": { "type": "number" },

                                "multiple": {
                                    "type": "boolean",
                                    "description": "For media/component relations where multiple values are allowed."
                                },

                                "enum": {
                                    "type": "array",
                                    "items": { "type": "string" },
                                    "description": "Allowed values for enumeration."
                                },

                                "relation": {
                                    "type": "string",
                                    "enum": [
                                        "oneToOne",
                                        "oneToMany",
                                        "manyToOne",
                                        "manyToMany",
                                        "morphToOne",
                                        "morphToMany"
                                    ],
                                    "description": "Strapi relation type. Polymorphic values included."
                                },
                                "target": {
                                    "type": "string",
                                    "description": "Target content-type UID (e.g., api::article.article, plugin::users-permissions.user, strapi::role, or custom namespaces)."
                                },
                                "inversedBy": {
                                    "type": "string",
                                    "description": "Name of the attribute on the target that inverses this relation."
                                },
                                "mappedBy": {
                                    "type": "string",
                                    "description": "Name of the attribute on the source used to map the relation when required."
                                },

                                "component": {
                                    "type": "string",
                                    "description": "Component UID (e.g., shared.address). Used when type = component."
                                },

                                "components": {
                                    "type": "array",
                                    "description": "List of component UIDs for dynamic zones.",
                                    "items": { "type": "string" }
                                },

                                "repeatable": {
                                    "type": "boolean",
                                    "description": "For component attributes to allow multiple entries."
                                },

                                "allowedTypes": {
                                    "type": "array",
                                    "items": {
                                        "type": "string",
                                        "enum": [
                                            "images",
                                            "files",
                                            "videos",
                                            "audios"
                                        ]
                                    },
                                    "description": "Media allowed types filter."
                                },

                                "maxSize": {
                                    "type": "number",
                                    "description": "Max media size in MB."
                                },

                                "targetField": {
                                    "type": "string",
                                    "description": "For UID fields: the attribute whose value populates the UID."
                                },

                                "config": {
                                    "type": "object",
                                    "description": "Advanced attribute config (indices, custom options, ACL).",
                                    "additionalProperties": true
                                },

                                "index": {
                                    "type": "boolean",
                                    "description": "Hint to create an index; actual support is defined by Strapi/DB layer."
                                },

                                "computed": {
                                    "type": "boolean",
                                    "description": "When true, this field is computed server-side and not directly writable. The value is derived from other fields via the 'depends' and 'compute' properties."
                                },
                                "depends": {
                                    "type": "array",
                                    "items": { "type": "string" },
                                    "description": "List of field paths that trigger recomputation of this computed field. Supports dot notation for related fields (e.g., 'lines.priceSubtotal'). Only valid when computed=true."
                                },
                                "compute": {
                                    "type": "string",
                                    "description": "Expression or function name defining how the field value is derived. Can be a simple expression (e.g., 'sum(lines.priceSubtotal)') or a method reference. Only valid when computed=true."
                                },
                                "stored": {
                                    "type": "boolean",
                                    "description": "When true, the computed value is persisted in the database (materialized). When false, it is calculated on-the-fly. Default: true. Only valid when computed=true."
                                }
                            },

                            "allOf": [
                                {
                                    "if": {
                                        "properties": {
                                            "type": { "const": "enumeration" }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": { "required": ["enum"] }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": { "const": "uid" }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "properties": {
                                            "targetField": { "type": "string" }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": { "const": "relation" }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "required": [
                                            "relation",
                                            "target",
                                            "mappedBy"
                                        ],
                                        "properties": {
                                            "target": {
                                                "type": "string",
                                                "pattern": "[A-Za-z0-9_-]+$"
                                            }
                                        }
                                    },
                                    "else": {
                                        "not": {
                                            "anyOf": [
                                                { "required": ["relation"] },
                                                { "required": ["target"] },
                                                { "required": ["inversedBy"] },
                                                { "required": ["mappedBy"] }
                                            ]
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": { "const": "component" }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "required": ["component"],
                                        "properties": {
                                            "component": {
                                                "type": "string",
                                                "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$",
                                                "description": "Component UID: <category>.<component>"
                                            },
                                            "repeatable": { "type": "boolean" }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": { "const": "dynamiczone" }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "required": ["components"],
                                        "properties": {
                                            "components": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string",
                                                    "pattern": "^[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+$"
                                                },
                                                "minItems": 1
                                            }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "enum": [
                                                    "integer",
                                                    "biginteger"
                                                ]
                                            }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "properties": {
                                            "min": { "type": "integer" },
                                            "max": { "type": "integer" }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "enum": ["float", "decimal"]
                                            }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "properties": {
                                            "min": { "type": "number" },
                                            "max": { "type": "number" }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "enum": [
                                                    "string",
                                                    "text",
                                                    "richtext",
                                                    "password",
                                                    "email",
                                                    "uid"
                                                ]
                                            }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "properties": {
                                            "minLength": {
                                                "type": "integer",
                                                "minimum": 0
                                            },
                                            "maxLength": {
                                                "type": "integer",
                                                "minimum": 0
                                            },
                                            "regex": { "type": "string" }
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "type": {
                                                "not": {
                                                    "enum": [
                                                        "integer",
                                                        "biginteger",
                                                        "float",
                                                        "decimal"
                                                    ]
                                                }
                                            }
                                        },
                                        "required": ["type"]
                                    },
                                    "then": {
                                        "not": {
                                            "anyOf": [
                                                { "required": ["min"] },
                                                { "required": ["max"] }
                                            ]
                                        }
                                    }
                                },
                                {
                                    "if": {
                                        "properties": {
                                            "computed": { "const": true }
                                        },
                                        "required": ["computed"]
                                    },
                                    "then": {
                                        "required": ["depends", "compute"],
                                        "properties": {
                                            "depends": {
                                                "type": "array",
                                                "minItems": 1
                                            },
                                            "compute": {
                                                "type": "string",
                                                "minLength": 1
                                            }
                                        }
                                    }
                                }
                            ],

                            "additionalProperties": true
                        }
                    },

                    "additionalProperties": true
                }
            },

            "additionalProperties": true
        }
    },

    "additionalProperties": false
}
