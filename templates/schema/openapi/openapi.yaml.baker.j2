{%- import "macros.jinja" as macros -%}
{#- OpenAPI type mapping macro -#}
{%- macro get_openapi_type(name, property) -%}
{%- if property.type == 'string' -%}
type: string
{%- if property.format %}
          format: {{ property.format }}
{%- endif %}
{%- if property.maxLength %}
          maxLength: {{ property.maxLength }}
{%- endif %}
{%- if property.minLength %}
          minLength: {{ property.minLength }}
{%- endif %}
{%- elif property.type == 'text' -%}
type: string
{%- elif property.type == 'integer' -%}
type: integer
{%- if property.minimum is defined %}
          minimum: {{ property.minimum }}
{%- endif %}
{%- if property.maximum is defined %}
          maximum: {{ property.maximum }}
{%- endif %}
{%- elif property.type == 'float' or property.type == 'decimal' -%}
type: number
          format: double
{%- elif property.type == 'boolean' -%}
type: boolean
{%- elif property.type == 'email' -%}
type: string
          format: email
{%- elif property.type == 'datetime' -%}
type: string
          format: date-time
{%- elif property.type == 'date' -%}
type: string
          format: date
{%- elif property.type == 'json' -%}
type: object
{%- elif property.type == 'uid' -%}
type: string
          format: uuid
{%- elif property.type == 'enumeration' -%}
type: string
          enum:
{%- for value in property.enum %}
            - {{ value }}
{%- endfor %}
{%- elif property.type == 'relation' -%}
{%- if macros.relation_is_many_to_many(property) == 'true' or macros.relation_is_one_to_many(property) == 'true' -%}
type: array
          items:
            $ref: '#/components/schemas/{{ property.target }}'
{%- else -%}
$ref: '#/components/schemas/{{ property.target }}'
{%- endif %}
{%- else -%}
type: string
{%- endif %}
{%- endmacro -%}

{#- Macro to get simple type for request schemas (relations as IDs) -#}
{%- macro get_openapi_request_type(name, property) -%}
{%- if property.type == 'relation' -%}
{%- if macros.relation_is_many_to_many(property) == 'true' or macros.relation_is_one_to_many(property) == 'true' -%}
type: array
          items:
            type: string
            format: uuid
          description: Array of {{ property.target }} IDs
{%- else -%}
type: string
          format: uuid
          description: {{ property.target }} ID
{%- endif %}
{%- else -%}
{{ get_openapi_type(name, property) }}
{%- endif %}
{%- endmacro -%}

openapi: 3.0.3
info:
  title: {{ project_name | title | replace('_', ' ') }} API
  description: REST API for {{ project_name | title | replace('_', ' ') }}
  version: 1.0.0
  contact:
    name: API Support
servers:
  - url: http://localhost:{{ port | default(8080) }}
    description: Local development server
  - url: https://api.{{ project_name | snake_case | replace('_', '-') }}.com
    description: Production server

tags:
{% for entity_name, entity in entities | items | sort(attribute='1.priority') %}
  - name: {{ entity_name | title }}
    description: {{ entity.info.description | default(entity_name ~ ' management endpoints') }}
{% endfor %}

paths:
{% for entity_name, entity in entities | items | sort(attribute='1.priority') %}
{% set resource = entity_name | plural | kebab_case %}
{% set model = entity_name | pascal_case %}
{% set model_plural = entity_name | plural | pascal_case %}
  /{{ resource }}:
    get:
      tags:
        - {{ entity_name | title }}
      summary: List all {{ entity_name | plural | lower }}
      description: Retrieve a paginated list of {{ entity_name | plural | lower }}
      operationId: list{{ model_plural }}
      parameters:
        - name: page
          in: query
          description: Page number (1-indexed)
          schema:
            type: integer
            default: 1
            minimum: 1
        - name: page_size
          in: query
          description: Number of items per page
          schema:
            type: integer
            default: 20
            minimum: 1
            maximum: 100
        - name: sort_by
          in: query
          description: Field to sort by
          schema:
            type: string
            enum:
              - created_at
              - updated_at
{% for attr_name, attr in entity.attributes | items %}
{% if attr.type != 'relation' %}
              - {{ attr_name }}
{% endif %}
{% endfor %}
        - name: sort_order
          in: query
          description: Sort order
          schema:
            type: string
            enum:
              - asc
              - desc
            default: desc
      responses:
        '200':
          description: Successful response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ model_plural }}Response'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '500':
          $ref: '#/components/responses/InternalServerError'

    post:
      tags:
        - {{ entity_name | title }}
      summary: Create a new {{ entity_name | lower }}
      description: Create a new {{ entity_name | lower }} record
      operationId: create{{ model }}
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Create{{ model }}Request'
      responses:
        '201':
          description: {{ entity_name | title }} created successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ model }}'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '422':
          $ref: '#/components/responses/UnprocessableEntity'
        '500':
          $ref: '#/components/responses/InternalServerError'

  /{{ resource }}/{id}:
    get:
      tags:
        - {{ entity_name | title }}
      summary: Get a {{ entity_name | lower }} by ID
      description: Retrieve a single {{ entity_name | lower }} by its unique identifier
      operationId: get{{ model }}
      parameters:
        - name: id
          in: path
          required: true
          description: Unique identifier of the {{ entity_name | lower }}
          schema:
            type: string
            format: uuid
      responses:
        '200':
          description: Successful response
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ model }}'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

    put:
      tags:
        - {{ entity_name | title }}
      summary: Update a {{ entity_name | lower }}
      description: Replace an existing {{ entity_name | lower }} with new data
      operationId: update{{ model }}
      parameters:
        - name: id
          in: path
          required: true
          description: Unique identifier of the {{ entity_name | lower }}
          schema:
            type: string
            format: uuid
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Update{{ model }}Request'
      responses:
        '200':
          description: {{ entity_name | title }} updated successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ model }}'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '422':
          $ref: '#/components/responses/UnprocessableEntity'
        '500':
          $ref: '#/components/responses/InternalServerError'

    patch:
      tags:
        - {{ entity_name | title }}
      summary: Partially update a {{ entity_name | lower }}
      description: Update specific fields of an existing {{ entity_name | lower }}
      operationId: patch{{ model }}
      parameters:
        - name: id
          in: path
          required: true
          description: Unique identifier of the {{ entity_name | lower }}
          schema:
            type: string
            format: uuid
      requestBody:
        required: true
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/Patch{{ model }}Request'
      responses:
        '200':
          description: {{ entity_name | title }} patched successfully
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/{{ model }}'
        '400':
          $ref: '#/components/responses/BadRequest'
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '422':
          $ref: '#/components/responses/UnprocessableEntity'
        '500':
          $ref: '#/components/responses/InternalServerError'

    delete:
      tags:
        - {{ entity_name | title }}
      summary: Delete a {{ entity_name | lower }}
      description: Remove a {{ entity_name | lower }} by its unique identifier
      operationId: delete{{ model }}
      parameters:
        - name: id
          in: path
          required: true
          description: Unique identifier of the {{ entity_name | lower }}
          schema:
            type: string
            format: uuid
      responses:
        '204':
          description: {{ entity_name | title }} deleted successfully
        '401':
          $ref: '#/components/responses/Unauthorized'
        '404':
          $ref: '#/components/responses/NotFound'
        '500':
          $ref: '#/components/responses/InternalServerError'

{% endfor %}
components:
  schemas:
{% for entity_name, entity in entities | items %}
{% set model = entity_name | pascal_case %}
{% set model_plural = entity_name | plural | pascal_case %}
    # {{ model }} Schemas
    {{ model }}:
      type: object
      description: {{ entity.info.description | default(entity_name ~ ' entity') }}
      required:
        - id
        - created_at
        - updated_at
{% for attr_name, attr in entity.attributes | items %}
{% if attr.required %}
        - {{ attr_name }}
{% endif %}
{% endfor %}
      properties:
        id:
          type: string
          format: uuid
          description: Unique identifier
          readOnly: true
        created_at:
          type: string
          format: date-time
          description: Creation timestamp
          readOnly: true
        updated_at:
          type: string
          format: date-time
          description: Last update timestamp
          readOnly: true
{% for attr_name, attr in entity.attributes | items %}
        {{ attr_name }}:
          {{ get_openapi_type(attr_name, attr) }}
{% if attr.description %}
          description: {{ attr.description }}
{% endif %}
{% if attr.default is defined %}
          default: {{ attr.default }}
{% endif %}
{% endfor %}

    Create{{ model }}Request:
      type: object
      description: Request body for creating a {{ entity_name | lower }}
{% set required_attrs = entity.attributes | items | selectattr('1.required') | list %}
{% if required_attrs | length > 0 %}
      required:
{% for attr_name, attr in required_attrs %}
{% if attr.type != 'relation' or macros.relation_is_many_to_one(attr) == 'true' or macros.relation_is_one_to_one(attr) == 'true' %}
        - {{ attr_name }}{% if attr.type == 'relation' %}_id{% endif %}

{% endif %}
{% endfor %}
{% endif %}
      properties:
{% for attr_name, attr in entity.attributes | items %}
{% if attr.type == 'relation' %}
{% if macros.relation_is_many_to_one(attr) == 'true' or macros.relation_is_one_to_one(attr) == 'true' %}
        {{ attr_name }}_id:
          type: string
          format: uuid
          description: {{ attr.target }} ID
{% elif macros.relation_is_many_to_many(attr) == 'true' %}
        {{ attr_name }}_ids:
          type: array
          items:
            type: string
            format: uuid
          description: Array of {{ attr.target }} IDs
{% endif %}
{% else %}
        {{ attr_name }}:
          {{ get_openapi_type(attr_name, attr) }}
{% if attr.description %}
          description: {{ attr.description }}
{% endif %}
{% if attr.default is defined %}
          default: {{ attr.default }}
{% endif %}
{% endif %}
{% endfor %}

    Update{{ model }}Request:
      type: object
      description: Request body for updating a {{ entity_name | lower }}
{% if required_attrs | length > 0 %}
      required:
{% for attr_name, attr in required_attrs %}
{% if attr.type != 'relation' or macros.relation_is_many_to_one(attr) == 'true' or macros.relation_is_one_to_one(attr) == 'true' %}
        - {{ attr_name }}{% if attr.type == 'relation' %}_id{% endif %}

{% endif %}
{% endfor %}
{% endif %}
      properties:
{% for attr_name, attr in entity.attributes | items %}
{% if attr.type == 'relation' %}
{% if macros.relation_is_many_to_one(attr) == 'true' or macros.relation_is_one_to_one(attr) == 'true' %}
        {{ attr_name }}_id:
          type: string
          format: uuid
          description: {{ attr.target }} ID
{% elif macros.relation_is_many_to_many(attr) == 'true' %}
        {{ attr_name }}_ids:
          type: array
          items:
            type: string
            format: uuid
          description: Array of {{ attr.target }} IDs
{% endif %}
{% else %}
        {{ attr_name }}:
          {{ get_openapi_type(attr_name, attr) }}
{% if attr.description %}
          description: {{ attr.description }}
{% endif %}
{% endif %}
{% endfor %}

    Patch{{ model }}Request:
      type: object
      description: Request body for partially updating a {{ entity_name | lower }}
      properties:
{% for attr_name, attr in entity.attributes | items %}
{% if attr.type == 'relation' %}
{% if macros.relation_is_many_to_one(attr) == 'true' or macros.relation_is_one_to_one(attr) == 'true' %}
        {{ attr_name }}_id:
          type: string
          format: uuid
          description: {{ attr.target }} ID
{% elif macros.relation_is_many_to_many(attr) == 'true' %}
        {{ attr_name }}_ids:
          type: array
          items:
            type: string
            format: uuid
          description: Array of {{ attr.target }} IDs
{% endif %}
{% else %}
        {{ attr_name }}:
          {{ get_openapi_type(attr_name, attr) }}
{% if attr.description %}
          description: {{ attr.description }}
{% endif %}
{% endif %}
{% endfor %}

    {{ model_plural }}Response:
      type: object
      description: Paginated list of {{ entity_name | plural | lower }}
      required:
        - data
        - meta
      properties:
        data:
          type: array
          items:
            $ref: '#/components/schemas/{{ model }}'
        meta:
          $ref: '#/components/schemas/PaginationMeta'

{% endfor %}
    # Common Schemas
    PaginationMeta:
      type: object
      description: Pagination metadata
      required:
        - page
        - page_size
        - total_items
        - total_pages
      properties:
        page:
          type: integer
          description: Current page number
          example: 1
        page_size:
          type: integer
          description: Number of items per page
          example: 20
        total_items:
          type: integer
          description: Total number of items
          example: 100
        total_pages:
          type: integer
          description: Total number of pages
          example: 5

    Error:
      type: object
      required:
        - code
        - message
      properties:
        code:
          type: string
          description: Error code
        message:
          type: string
          description: Human-readable error message
        details:
          type: object
          description: Additional error details
          additionalProperties: true

  responses:
    BadRequest:
      description: Bad request - invalid input
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: BAD_REQUEST
            message: Invalid request parameters

    Unauthorized:
      description: Unauthorized - authentication required
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: UNAUTHORIZED
            message: Authentication is required

    NotFound:
      description: Resource not found
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: NOT_FOUND
            message: The requested resource was not found

    UnprocessableEntity:
      description: Validation error
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: VALIDATION_ERROR
            message: Validation failed
            details:
              field: Invalid value

    InternalServerError:
      description: Internal server error
      content:
        application/json:
          schema:
            $ref: '#/components/schemas/Error'
          example:
            code: INTERNAL_ERROR
            message: An unexpected error occurred

{% if authentication != 'none' %}
  securitySchemes:
{% if authentication == 'jwt' %}
    bearerAuth:
      type: http
      scheme: bearer
      bearerFormat: JWT
      description: JWT authentication token

security:
  - bearerAuth: []
{% elif authentication == 'api_key' %}
    apiKeyAuth:
      type: apiKey
      in: header
      name: X-API-Key
      description: API key for authentication

security:
  - apiKeyAuth: []
{% endif %}
{% endif %}
