{%- import "macros.jinja" as macros -%}
{%- import "sql/macros.jinja" as sql -%}
{%- set schema_name = db_schema | default('public') | trim -%}
-- Initial database migration (generated by saas-templates)
-- Applied automatically via diesel_migrations::embed_migrations! at startup.

{% if schema_name != 'public' -%}
CREATE SCHEMA IF NOT EXISTS {{ schema_name }};
{% endif -%}

CREATE EXTENSION IF NOT EXISTS pgcrypto;

CREATE OR REPLACE FUNCTION update_last_updated_column()
RETURNS TRIGGER AS $$
BEGIN
    NEW.last_updated = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

{% for entity_name, entity in entities | items | sort(attribute="1.priority") -%}
{% if entity.attributes -%}
{% set table_name = entity_name | table_case -%}

{% for name, property in entity.attributes | items -%}
{% if property.enum -%}
DO $$
BEGIN
    IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = '{{ name | snake_case }}_enum') THEN
        CREATE TYPE {{ schema_name }}.{{ name | snake_case }}_enum AS ENUM (
            {{ "'" ~ (property.enum | map('string') | join("', '")) ~ "'" }}
        );
    END IF;
END $$;

{% endif -%}
{% endfor -%}

CREATE TABLE IF NOT EXISTS {{ schema_name }}.{{ table_name }} (
    {{ sql.pk_column_definition(id_type) }},
    created_at TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    last_updated TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    {% if macros.entity_has_rls(entity, row_level_security)|trim == 'true' -%}
    tenant_id VARCHAR NOT NULL,
    {% endif -%}
    {% for name, property in entity.attributes | items -%}
    {%- set is_required = name in (entity.required | default([])) or property.required | default(false) -%}
    {%- if macros.is_relation(property) == 'true' -%}
        {%- if macros.relation_is_many_to_one(property) == 'true' or macros.relation_is_one_to_one(property) == 'true' -%}
    {{ name | snake_case }}_id {{ sql.foreign_key_column_type(id_type) }}{{ ' NOT NULL' if is_required }},
        {%- endif -%}
    {%- elif property.type == 'string' or property.type == 'email' -%}
    {{ name | snake_case }} VARCHAR{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'text' -%}
    {{ name | snake_case }} TEXT{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'integer' -%}
    {{ name | snake_case }} INTEGER{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'biginteger' -%}
    {{ name | snake_case }} BIGINT{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'float' or property.type == 'decimal' -%}
    {{ name | snake_case }} DOUBLE PRECISION{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'boolean' -%}
    {{ name | snake_case }} BOOLEAN{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'datetime' or property.type == 'timestamp' -%}
    {{ name | snake_case }} TIMESTAMP{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'date' -%}
    {{ name | snake_case }} DATE{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'time' -%}
    {{ name | snake_case }} TIME{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'json' -%}
    {{ name | snake_case }} JSONB{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'uid' -%}
    {{ name | snake_case }} UUID{{ ' NOT NULL' if is_required }},
    {%- elif property.type == 'enumeration' -%}
    {{ name | snake_case }} {{ schema_name }}.{{ name | snake_case }}_enum{{ ' NOT NULL' if is_required }},
    {%- endif -%}
    {% endfor -%}
    PRIMARY KEY (id)
);

DROP TRIGGER IF EXISTS set_last_updated ON {{ schema_name }}.{{ table_name }};
CREATE TRIGGER set_last_updated
    BEFORE UPDATE ON {{ schema_name }}.{{ table_name }}
    FOR EACH ROW EXECUTE FUNCTION update_last_updated_column();

{% if macros.entity_has_rls(entity, row_level_security)|trim == 'true' -%}
ALTER TABLE {{ schema_name }}.{{ table_name }} ENABLE ROW LEVEL SECURITY;
ALTER TABLE {{ schema_name }}.{{ table_name }} FORCE ROW LEVEL SECURITY;

CREATE POLICY tenant_isolation ON {{ schema_name }}.{{ table_name }}
    USING (tenant_id = current_setting('app.current_tenant'))
    WITH CHECK (tenant_id = current_setting('app.current_tenant'));

CREATE INDEX IF NOT EXISTS idx_{{ table_name }}_tenant_id ON {{ schema_name }}.{{ table_name }} (tenant_id);
{% endif -%}

{% endif -%}
{% endfor -%}

-- Foreign key constraints (added after all tables are created to avoid ordering issues)
{% for entity_name, entity in entities | items | sort(attribute="1.priority") -%}
{% if entity.attributes -%}
{% set table_name = entity_name | table_case -%}
{% for name, property in entity.attributes | items -%}
{%- if macros.is_relation(property) == 'true' -%}
    {%- if macros.relation_is_many_to_one(property) == 'true' or macros.relation_is_one_to_one(property) == 'true' -%}
ALTER TABLE {{ schema_name }}.{{ table_name }}
    ADD CONSTRAINT fk_{{ table_name }}_{{ name | snake_case }}
    FOREIGN KEY ({{ name | snake_case }}_id) REFERENCES {{ schema_name }}.{{ property.target | table_case }}(id);
{% endif -%}
{%- endif -%}
{% endfor -%}
{% endif -%}
{% endfor -%}

-- Many-to-many junction tables
{% for relation in macros.get_m2m_relations(entities) | split(',') -%}
{% if relation | trim != '' -%}
{% set left = relation | split('_') | first -%}
{% set right = relation | split('_') | last -%}
{% set left_fk = left | foreign_key | trim -%}
{% set right_fk = right | foreign_key | trim -%}
{% set rel_name = relation | trim -%}
CREATE TABLE IF NOT EXISTS {{ schema_name }}.{{ rel_name }} (
    {{ left_fk }} {{ sql.foreign_key_column_type(id_type) }} NOT NULL
        REFERENCES {{ schema_name }}.{{ left | table_case }}(id) ON DELETE CASCADE,
    {{ right_fk }} {{ sql.foreign_key_column_type(id_type) }} NOT NULL
        REFERENCES {{ schema_name }}.{{ right | table_case }}(id) ON DELETE CASCADE,
    PRIMARY KEY ({{ left_fk }}, {{ right_fk }})
);

{% endif -%}
{% endfor -%}
