#[Object]
impl {{ model }}Query {
    /// Get a single {{ model }} by ID.
    async fn {{ entity_name | snake_case }}(&self, ctx: &Context<'_>, id: i32) -> GqlResult<Option<{{ model }}Gql>> {
        let db = ctx.data::<DbConn>()?;
        let model = Entity::find_by_id(id)
            .one(db)
            .await
            .map_err(|e| async_graphql::Error::new(e.to_string()))?;
        Ok(model.map(Into::into))
    }

    /// List all {{ entity.info.pluralName }}.
    async fn {{ entity.info.pluralName | snake_case }}(&self, ctx: &Context<'_>) -> GqlResult<Vec<{{ model }}Gql>> {
        let db = ctx.data::<DbConn>()?;
        let models = Entity::find()
            .all(db)
            .await
            .map_err(|e| async_graphql::Error::new(e.to_string()))?;
        Ok(models.into_iter().map(Into::into).collect())
