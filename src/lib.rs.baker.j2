/// Returns the Leptos SPA router with a fallback to `index.html` so that
/// client-side routing works correctly when the user refreshes the app.
pub fn leptos_router() -> ::summer_web::axum::Router {
    use ::summer_web::axum::{
        body::Body,
        http::{header, StatusCode},
        response::Response,
        routing::get,
    };
    static INDEX: &[u8] =
        include_bytes!(concat!(env!("CARGO_MANIFEST_DIR"), "/frontend/dist/index.html"));

    static_router().fallback(get(|| async move {
        Response::builder()
            .status(StatusCode::OK)
            .header(header::CONTENT_TYPE, "text/html; charset=utf-8")
            .body(Body::from(INDEX))
            .expect("failed to build fallback response")
    }))
}
