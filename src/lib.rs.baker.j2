/// Build the fully-initialised axum [`Router`] without binding a TCP listener.
///
/// Intended for integration tests only – guarded by `#[cfg(test)]`.
/// Runs every registered plugin's `build()` hook (database connection, auth, …)
/// and extracts the composed router, ready for [`axum_test::TestServer`].
#[cfg(test)]
pub async fn create_app() -> anyhow::Result<summer_web::axum::Router> {
    use std::ops::Deref;
    use std::sync::Arc;
    use summer::App;
    use summer::plugin::ComponentRegistry;
    {{ 'use summer_sea_orm::SeaOrmPlugin;' if database != 'none' }}
    use summer_web::{AppState, RouterLayers, WebConfigurator, WebPlugin};
    {{ 'use crate::services::seaorm_migration_plugin::SeaOrmMigrationPlugin;' if use_seaorm_migrations }}
    {% if authentication == 'jwt' -%}
    use crate::services::auth_plugin::AuthPlugin;
    {% endif -%}

    let app: Arc<summer::App> = App::new()
        .add_router(::summer_web::handler::auto_router())
        {{ '.add_plugin(SeaOrmPlugin)' if database != 'none' }}
        {{ '.add_plugin(AuthPlugin)' if authentication == 'jwt' }}
        {{ '.add_plugin(SeaOrmMigrationPlugin)' if use_seaorm_migrations }}
        .add_plugin(WebPlugin)
        .build()
        .await?;

    let mut router = app
        .get_component::<summer_web::Router>()
        .expect("Router not found – ensure WebPlugin was added");

    if let Some(layers) = app.get_component_ref::<RouterLayers>() {
        let layers: summer_web::RouterLayers = layers.deref().clone();
        for layer_fn in layers.iter() {
            router = layer_fn(router);
        }
    }

    Ok(router.layer(summer_web::axum::Extension(AppState { app })))
}
{% endif -%}
