/// Publish an activity to all configured federation peers and record in outbox.
///
/// Sends an HTTP POST to each peer's server inbox (`/ap/actor/inbox`).
/// Errors are logged but do not fail the operation (fire-and-forget).
pub async fn publish_activity(activity: Value) {
    // Record in outbox.
    {
        let mut ob = outbox().write().unwrap();
        ob.push(activity.clone());
    }

    let peers = federation_peers();
    if peers.is_empty() {
        debug!("AP: No peers configured, activity stored in outbox only");
        return;
    }

    let client = reqwest::Client::new();
    for peer in peers {
        let inbox_url = format!("{}/ap/actor/inbox", peer.trim_end_matches('/'));
        debug!("AP: Delivering activity to peer inbox: {}", inbox_url);

        let result = client
            .post(&inbox_url)
            .header("Content-Type", AP_CONTENT_TYPE)
            .json(&activity)
            .send()
            .await;

        match result {
            Ok(resp) => {
                if resp.status().is_success() || resp.status().as_u16() == 202 {
                    debug!("AP: Successfully delivered to {}", inbox_url);
                } else {
                    warn!(
                        "AP: Peer {} returned status {} for activity delivery",
                        inbox_url,
                        resp.status()
                    );
                }
            }
            Err(e) => {
                warn!("AP: Failed to deliver activity to {}: {}", inbox_url, e);
            }
        }
    }
}

/// Convenience: build and publish a Create activity.
pub async fn send_create_event(entity_type: &str, entity_id: &str, data: &Value) {
    let activity = build_create_activity(entity_type, entity_id, data);
    publish_activity(activity).await;
}

/// Convenience: build and publish an Update activity.
pub async fn send_update_event(entity_type: &str, entity_id: &str, data: &Value) {
    let activity = build_update_activity(entity_type, entity_id, data);
    publish_activity(activity).await;
}

/// Convenience: build and publish a Delete activity.
pub async fn send_delete_event(entity_type: &str, entity_id: &str) {
    let activity = build_delete_activity(entity_type, entity_id);
    publish_activity(activity).await;
}

// ─── Inbox Processing ─────────────────────────────────────────────────────────

/// Process an incoming ActivityPub activity by applying it to the local database.
async fn process_inbox_activity(db: &DbConn, activity: &Value) -> std::result::Result<(), String> {
    let activity_type = activity
        .get("type")
        .and_then(|v| v.as_str())
        .unwrap_or("Unknown");
    let object = activity.get("object").ok_or("missing object")?;
    let entity_type = object
        .get("entityType")
        .and_then(|v| v.as_str())
        .ok_or("missing entityType in object")?;
    let entity_id = object
        .get("entityId")
        .and_then(|v| v.as_str())
        .ok_or("missing entityId in object")?;

    debug!(
        "AP inbox: processing {} for {} id={}",
        activity_type, entity_type, entity_id
    );

    match activity_type {
        "Create" => {
            let content = object.get("content").ok_or("missing content in Create object")?;
            process_create(db, entity_type, content).await
        }
        "Update" => {
            let content = object.get("content").ok_or("missing content in Update object")?;
            let id: i32 = entity_id.parse().map_err(|_| "invalid entity id")?;
            process_update(db, entity_type, id, content).await
        }
        "Delete" => {
            let id: i32 = entity_id.parse().map_err(|_| "invalid entity id")?;
            process_delete(db, entity_type, id).await
        }
        _ => {
            debug!("AP inbox: ignoring unsupported activity type '{}'", activity_type);
            Ok(())
        }
    }
}

/// Insert a new entity from an incoming Create activity.
async fn process_create(db: &DbConn, entity_type: &str, content: &Value) -> std::result::Result<(), String> {
    match entity_type {
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% if macros.entity_has_protocol(entity, 'activitypub', protocols) | trim == 'true' -%}
        "{{ entity.info.pluralName | kebab_case }}" => {
            use crate::models::{{ rust_types.identifier(entity_name) }}::{{entity_name | pascal_case}}Create;
            let create: {{entity_name | pascal_case}}Create = serde_json::from_value(content.clone())
                .map_err(|e| format!("failed to parse {{ entity_name }} Create content: {}", e))?;
            let active_model = create.into_active_model();
            active_model.insert(db).await
                .map_err(|e| format!("failed to insert {{ entity_name }}: {}", e))?;
            Ok(())
        }
{% endif -%}
{% endfor -%}
        _ => {
            debug!("AP inbox: unknown entity type '{}' for Create", entity_type);
            Ok(())
        }
    }
}

/// Update an existing entity from an incoming Update activity.
async fn process_update(db: &DbConn, entity_type: &str, id: i32, content: &Value) -> std::result::Result<(), String> {
    match entity_type {
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% if macros.entity_has_protocol(entity, 'activitypub', protocols) | trim == 'true' -%}
        "{{ entity.info.pluralName | kebab_case }}" => {
            use crate::models::{{ rust_types.identifier(entity_name) }}::{Entity, {{entity_name | pascal_case}}Update};
            Entity::find_by_id(id).one(db).await
                .map_err(|e| format!("DB error: {}", e))?
                .ok_or_else(|| format!("{{ entity_name }} {} not found", id))?;
            let update: {{entity_name | pascal_case}}Update = serde_json::from_value(content.clone())
                .map_err(|e| format!("failed to parse {{ entity_name }} Update content: {}", e))?;
            let mut active_model = update.into_active_model();
            active_model.id = Set(id);
            active_model.update(db).await
                .map_err(|e| format!("failed to update {{ entity_name }}: {}", e))?;
            Ok(())
        }
{% endif -%}
{% endfor -%}
        _ => {
            debug!("AP inbox: unknown entity type '{}' for Update", entity_type);
            Ok(())
        }
    }
}

/// Delete an entity from an incoming Delete activity.
async fn process_delete(db: &DbConn, entity_type: &str, id: i32) -> std::result::Result<(), String> {
    match entity_type {
{% for entity_name, entity in entities | items | selectattr("1.attributes") -%}
{% if macros.entity_has_protocol(entity, 'activitypub', protocols) | trim == 'true' -%}
        "{{ entity.info.pluralName | kebab_case }}" => {
            use crate::models::{{ rust_types.identifier(entity_name) }}::Entity;
            use sea_orm::ModelTrait;
            let model = Entity::find_by_id(id).one(db).await
