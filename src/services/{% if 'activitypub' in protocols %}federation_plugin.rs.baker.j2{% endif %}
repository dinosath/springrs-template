            model.delete(db).await
                .map_err(|e| format!("failed to delete {{ entity_name }}: {}", e))?;
            Ok(())
        }
{% endif -%}
{% endfor -%}
        _ => {
            debug!("AP inbox: unknown entity type '{}' for Delete", entity_type);
            Ok(())
        }
    }
}

// ─── WebFinger (RFC 7033) ─────────────────────────────────────────────────────

#[derive(Debug, Deserialize)]
pub struct WebFingerQuery {
    pub resource: String,
}

#[derive(Debug, Serialize)]
pub struct WebFingerResponse {
    pub subject: String,
    pub aliases: Vec<String>,
    pub links: Vec<WebFingerLink>,
}

#[derive(Debug, Serialize)]
pub struct WebFingerLink {
    pub rel: String,
    #[serde(rename = "type")]
    pub kind: String,
    pub href: String,
}

#[get("/.well-known/webfinger")]
pub async fn webfinger(Query(params): Query<WebFingerQuery>) -> Result<impl IntoResponse> {
    debug!("WebFinger request for resource: {}", params.resource);

    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let actor_url = format!("{}/ap/actor", base_url);

    let response = WebFingerResponse {
        subject: params.resource.clone(),
        aliases: vec![actor_url.clone()],
        links: vec![WebFingerLink {
            rel: "self".to_string(),
            kind: AP_CONTENT_TYPE.to_string(),
            href: actor_url,
        }],
    };

    let mut headers = HeaderMap::new();
    headers.insert("Content-Type", HeaderValue::from_static(WEBFINGER_CONTENT_TYPE));
    Ok((StatusCode::OK, headers, Json(response)))
}

// ─── Server-level actor ───────────────────────────────────────────────────────

#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct ServerActor {
    #[serde(rename = "@context")]
    pub context: Value,
    pub id: String,
    #[serde(rename = "type")]
    pub kind: String,
    pub name: String,
    pub preferred_username: String,
    pub inbox: String,
    pub outbox: String,
    pub followers: String,
    pub following: String,
    pub url: String,
    pub public_key: ActorPublicKey,
}

#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct ActorPublicKey {
    pub id: String,
    pub owner: String,
    pub public_key_pem: String,
}

#[get("/ap/actor")]
pub async fn actor() -> Result<impl IntoResponse> {
    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let actor_id = format!("{}/ap/actor", base_url);
    let kp = server_keypair();

    let actor = ServerActor {
        context: json!([AP_CONTEXT, SECURITY_CONTEXT]),
        id: actor_id.clone(),
        kind: "Application".to_string(),
        name: "{{ project_name }}".to_string(),
        preferred_username: "{{ project_name | snake_case }}".to_string(),
        inbox: format!("{}/inbox", actor_id),
        outbox: format!("{}/outbox", actor_id),
        followers: format!("{}/followers", actor_id),
        following: format!("{}/following", actor_id),
        url: base_url,
        public_key: ActorPublicKey {
            id: format!("{}#main-key", actor_id),
            owner: actor_id,
            public_key_pem: kp.public_key.clone(),
        },
    };

    Ok((StatusCode::OK, ap_headers(), Json(actor)))
}

// ─── Server Inbox / Outbox ────────────────────────────────────────────────────

#[post("/ap/actor/inbox")]
pub async fn server_inbox(
    Component(db): Component<DbConn>,
    Json(activity): Json<Value>,
) -> Result<impl IntoResponse> {
    let activity_type = activity
        .get("type")
        .and_then(|v| v.as_str())
        .unwrap_or("Unknown");
    let sender = activity
        .get("actor")
        .and_then(|v| v.as_str())
        .unwrap_or("unknown");

    debug!("AP: Server inbox received {} from {}", activity_type, sender);

    {
        let mut log = inbox_log().write().unwrap();
        log.push(activity.clone());
    }

    match process_inbox_activity(&db, &activity).await {
        Ok(()) => {
            debug!("AP: Successfully processed {} from {}", activity_type, sender);
        }
        Err(e) => {
            warn!("AP: Failed to process {} from {}: {}", activity_type, sender, e);
        }
    }

    Ok(StatusCode::ACCEPTED)
}

#[get("/ap/actor/outbox")]
pub async fn server_outbox() -> Result<impl IntoResponse> {
    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let items = read_outbox();

    let body = json!({
        "@context": AP_CONTEXT,
        "id": format!("{}/ap/actor/outbox", base_url),
        "type": "OrderedCollection",
        "totalItems": items.len(),
        "orderedItems": items,
    });

    Ok((StatusCode::OK, ap_headers(), Json(body)))
}

#[get("/ap/actor/inbox-log")]
pub async fn inbox_log_endpoint() -> Result<impl IntoResponse> {
    let items = read_inbox_log();

    let body = json!({
        "type": "InboxLog",
        "totalItems": items.len(),
        "items": items,
    });

    Ok((StatusCode::OK, ap_headers(), Json(body)))
}

