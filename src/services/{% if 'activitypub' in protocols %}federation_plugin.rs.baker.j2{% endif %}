// ─── Constants ────────────────────────────────────────────────────────────────

const AP_CONTEXT: &str = "https://www.w3.org/ns/activitystreams";
const SECURITY_CONTEXT: &str = "https://w3id.org/security/v1";
const AP_CONTENT_TYPE: &str = "application/activity+json";
const WEBFINGER_CONTENT_TYPE: &str = "application/jrd+json";

fn ap_headers() -> HeaderMap {
    let mut headers = HeaderMap::new();
    headers.insert("Content-Type", HeaderValue::from_static(AP_CONTENT_TYPE));
    headers
}

// ─── Shared federation data ───────────────────────────────────────────────────

#[derive(Clone)]
pub struct FederationData {
    pub db: DbConn,
    pub domain: String,
}

pub static FEDERATION: OnceLock<FederationConfig<Arc<FederationData>>> = OnceLock::new();

#[derive(Debug)]
pub struct ServerKeypair {
    pub public_key: String,
    pub private_key: String,
}

pub static SERVER_KEYPAIR: OnceLock<ServerKeypair> = OnceLock::new();

/// Peer instance base URLs for activity delivery.
pub static FEDERATION_PEERS: OnceLock<Vec<String>> = OnceLock::new();

/// In-memory outbox storing activities sent by this instance.
static OUTBOX: OnceLock<RwLock<Vec<Value>>> = OnceLock::new();

/// In-memory inbox log storing activities received by this instance.
static INBOX_LOG: OnceLock<RwLock<Vec<Value>>> = OnceLock::new();

fn outbox() -> &'static RwLock<Vec<Value>> {
    OUTBOX.get_or_init(|| RwLock::new(Vec::new()))
}

fn inbox_log() -> &'static RwLock<Vec<Value>> {
    INBOX_LOG.get_or_init(|| RwLock::new(Vec::new()))
}

// ─── Convenience accessors ────────────────────────────────────────────────────

pub fn federation_config() -> &'static FederationConfig<Arc<FederationData>> {
    FEDERATION
        .get()
        .expect("FederationPlugin must be added to the App before handling requests")
}

pub fn federation_data() -> activitypub_federation::config::Data<Arc<FederationData>> {
    federation_config().to_request_data()
}

pub fn server_keypair() -> &'static ServerKeypair {
    SERVER_KEYPAIR
        .get()
        .expect("FederationPlugin must be added to the App before handling requests")
}

pub fn federation_peers() -> &'static [String] {
    FEDERATION_PEERS
        .get()
        .map(|v| v.as_slice())
        .unwrap_or(&[])
}

/// Read the outbox contents (for tests and the outbox endpoint).
pub fn read_outbox() -> Vec<Value> {
    outbox().read().unwrap().clone()
}

/// Read the inbox log (for tests).
pub fn read_inbox_log() -> Vec<Value> {
    inbox_log().read().unwrap().clone()
}

// ─── Plugin ───────────────────────────────────────────────────────────────────

pub struct FederationPlugin;

#[async_trait]
impl Plugin for FederationPlugin {
    async fn build(&self, app: &mut AppBuilder) {
        let db = app
            .get_component::<DbConn>()
            .expect("DbConn not found – ensure SeaOrmPlugin is loaded before FederationPlugin");

        let domain = std::env::var("FEDERATION_DOMAIN")
            .unwrap_or_else(|_| "localhost:8080".to_string());

        info!("ActivityPub federation domain: {}", domain);

        // Parse peer URLs from FEDERATION_PEERS env var.
        let peers: Vec<String> = std::env::var("FEDERATION_PEERS")
            .unwrap_or_default()
            .split(',')
            .map(|s| s.trim().to_string())
            .filter(|s| !s.is_empty())
            .collect();

        if peers.is_empty() {
            info!("No federation peers configured (set FEDERATION_PEERS)");
        } else {
            info!("Federation peers: {:?}", peers);
        }
        let _ = FEDERATION_PEERS.set(peers);

        let data = Arc::new(FederationData {
            db,
            domain: domain.clone(),
        });

        let config = FederationConfig::builder()
            .domain(&domain)
            .app_data(data)
            .debug(cfg!(debug_assertions))
            .build()
            .await
            .expect("failed to build FederationConfig");

        if FEDERATION.set(config).is_err() {
            panic!("FederationPlugin initialised twice");
        }

        let keypair = generate_actor_keypair().expect("failed to generate server keypair");
        if SERVER_KEYPAIR
            .set(ServerKeypair {
                public_key: keypair.public_key,
                private_key: keypair.private_key,
            })
            .is_err()
        {
            panic!("ServerKeypair initialised twice");
        }
    }

    fn dependencies(&self) -> Vec<&str> {
        vec![std::any::type_name::<SeaOrmPlugin>()]
    }
}

// ─── AP Event Publishing ──────────────────────────────────────────────────────

/// Construct a Create activity for an entity.
pub fn build_create_activity(entity_type: &str, entity_id: &str, data: &Value) -> Value {
    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let actor_url = format!("{}/ap/actor", base_url);
    let activity_id = format!(
        "{}/ap/activities/create-{}-{}-{}",
        base_url,
        entity_type,
        entity_id,
        Utc::now().timestamp_millis()
    );

    json!({
        "@context": AP_CONTEXT,
        "type": "Create",
        "id": activity_id,
        "actor": actor_url,
        "published": Utc::now().format("%Y-%m-%dT%H:%M:%SZ").to_string(),
        "object": {
            "@context": AP_CONTEXT,
            "type": "Object",
            "id": format!("{}/ap/{}/{}", base_url, entity_type, entity_id),
            "attributedTo": actor_url,
            "entityType": entity_type,
            "entityId": entity_id,
            "content": data,
        }
    })
}

