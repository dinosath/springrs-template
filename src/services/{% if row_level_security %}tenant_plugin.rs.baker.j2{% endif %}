//! Multi-tenant Row-Level Security (RLS) plugin.
//!
//! Provides:
//! - [`TenantPlugin`] – no-op summer plugin (kept for API compatibility).
//! - [`TenantId`] – axum extractor for the resolved tenant.
//! - [`set_tenant`] – executes `SET LOCAL app.current_tenant` on a DB
//!   connection/transaction so PostgreSQL RLS policies take effect.
//!
//! ## Tenant resolution order
{% if authentication == 'jwt' -%}
//! 1. `X-Tenant-Id` HTTP header (explicit tenant context)
//! 2. JWT `user_id` claim (implicit personal tenant)
{% else -%}
//! 1. `X-Tenant-Id` HTTP header
{% endif -%}

use summer::async_trait;
use summer::{app::AppBuilder, plugin::Plugin};
use summer_web::WebPlugin;
use sea_orm::{ConnectionTrait, Statement, DbBackend};

// ─── TenantId extractor ────────────────────────────────────────────────────────

/// Tenant identifier extracted from the request.
///
/// Resolution order:
/// 1. `X-Tenant-Id` HTTP header
{% if authentication == 'jwt' -%}
/// 2. JWT `user_id` claim (implicit personal tenant)
{% endif -%}
#[derive(Clone, Debug)]
pub struct TenantId(pub String);

impl TenantId {
    /// Returns the tenant identifier as a `&str`.
    pub fn as_str(&self) -> &str {
        &self.0
    }
}

impl<S: Send + Sync> axum::extract::FromRequestParts<S> for TenantId {
    type Rejection = (axum::http::StatusCode, axum::Json<serde_json::Value>);

    async fn from_request_parts(
        parts: &mut axum::http::request::Parts,
        _state: &S,
    ) -> Result<Self, Self::Rejection> {
        // 1. Try X-Tenant-Id header
        if let Some(tenant) = parts
            .headers
            .get("x-tenant-id")
            .and_then(|v| v.to_str().ok())
        {
            return Ok(TenantId(tenant.to_owned()));
        }
{% if authentication == 'jwt' %}
        // 2. Fall back to JWT user_id claim
        use axum::http::header::AUTHORIZATION;
        use webgates::codecs::Codec;
        if let Some(token) = parts
            .headers
            .get(AUTHORIZATION)
            .and_then(|v| v.to_str().ok())
            .and_then(|v| v.strip_prefix("Bearer "))
        {
            if let Some(auth) = crate::services::auth_plugin::AUTH_STATE.get() {
                if let Ok(claims) = auth.jwt_codec.decode(token.as_bytes()) {
                    return Ok(TenantId(claims.custom_claims.user_id.clone()));
                }
            }
        }
{% endif %}
        Err((
            axum::http::StatusCode::UNAUTHORIZED,
            axum::Json(serde_json::json!({"error": "Missing tenant identifier – provide X-Tenant-Id header"})),
        ))
    }
}

// ─── set_tenant helper ─────────────────────────────────────────────────────────

/// Switches to the `app_rls_user` role and sets the current-tenant GUC so that
/// PostgreSQL RLS policies filter rows for this tenant.
///
/// Both operations are scoped to the current transaction (`SET LOCAL`/`true`),
/// so they are automatically undone when the transaction commits or rolls back.
///
/// **Why SET LOCAL ROLE?**  PostgreSQL superusers bypass ALL row-level security
/// policies even when `FORCE ROW LEVEL SECURITY` is set.  By switching to the
/// non-superuser `app_rls_user` role within the transaction, the RLS policies
/// are evaluated normally.
pub async fn set_tenant<C: ConnectionTrait>(db: &C, tenant: &TenantId) -> Result<(), sea_orm::DbErr> {
    // Switch to the non-superuser role so RLS is enforced (superusers bypass RLS).
    db.execute_unprepared("SET LOCAL ROLE app_rls_user").await?;
    // Set the tenant GUC for the current transaction.
    let stmt = Statement::from_sql_and_values(
        DbBackend::Postgres,
        "SELECT set_config('app.current_tenant', $1, true)",
        [tenant.as_str().into()],
    );
    db.execute_raw(stmt).await?;
    Ok(())
}

