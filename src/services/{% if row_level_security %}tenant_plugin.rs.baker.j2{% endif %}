//! Multi-tenant Row-Level Security (RLS) plugin.
//!
//! Uses the [`tenant-axum`] crate for tenant resolution and injects the
//! resolved [`TenantId`] into request extensions via [`TenantLayer`].
//!
//! Provides:
//! - [`TenantPlugin`] ‚Äì registers the `TenantLayer` middleware.
//! - [`CurrentTenant`] ‚Äì axum extractor for the resolved tenant.
//! - [`set_tenant`] ‚Äì executes `SET LOCAL app.current_tenant` on a DB
//!   connection/transaction so PostgreSQL RLS policies take effect.
//!
//! ## Tenant resolution order
{% if authentication == 'jwt' -%}
//! 1. `X-Tenant-Id` HTTP header (explicit tenant context)
//! 2. JWT `user_id` claim (implicit personal tenant)
{% else -%}
//! 1. `X-Tenant-Id` HTTP header
{% endif -%}

use std::sync::Arc;

use summer::async_trait;
use summer::{app::AppBuilder, plugin::{Plugin, ComponentRegistry, MutableComponentRegistry}};
use summer_web::{WebPlugin, RouterLayers};
use sea_orm::{ConnectionTrait, Statement, DbBackend};
use tenant_axum::{
    CompositeTenantResolver, CurrentTenant, HeaderTenantResolver, TenantLayer,
{% if authentication == 'jwt' -%}
    JwtTenantResolver,
{% endif -%}
};

pub use tenant_axum::CurrentTenant as TenantId;

// ‚îÄ‚îÄ‚îÄ set_tenant helper ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ‚îÄ

/// Executes `SET LOCAL app.current_tenant = '<tenant_id>'` on the given
/// connection so that PostgreSQL RLS policies filter rows for this tenant.
///
/// **Must** be called inside a transaction (`BEGIN ‚Ä¶ COMMIT`) for `SET LOCAL`
/// to be scoped correctly.  Outside a transaction the setting persists for the
/// session ‚Äî which is usually *not* what you want in a connection-pooled setup.
pub async fn set_tenant<C: ConnectionTrait>(db: &C, tenant: &CurrentTenant) -> Result<(), sea_orm::DbErr> {
    let stmt = Statement::from_sql_and_values(
        DbBackend::Postgres,
        "SELECT set_config('app.current_tenant', $1, true)",
        [tenant.as_str().into()],
    );
    db.execute_raw(stmt).await?;
    Ok(())
}

