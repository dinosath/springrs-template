/// Summer plugin that registers the [`TenantLayer`] middleware for tenant
/// resolution.
pub struct TenantPlugin;

#[async_trait]
impl Plugin for TenantPlugin {
    async fn build(&self, app: &mut AppBuilder) {
{% if authentication == 'jwt' -%}
        let resolver = CompositeTenantResolver::new()
            .add(HeaderTenantResolver::default())
            .add(JwtTenantResolver::new("user_id"));
{% else -%}
        let resolver = CompositeTenantResolver::new()
            .add(HeaderTenantResolver::default());
{% endif -%}

        let tenant_layer = TenantLayer::new(resolver)
            .with_skip_paths(vec!["/api/health", "/api/auth/register", "/api/auth/login", "/api/auth/logout", "/api/auth/me"]);

        let layer_fn: Arc<dyn Fn(summer_web::Router) -> summer_web::Router + Send + Sync> =
            Arc::new(move |router| {
                router.layer(tenant_layer.clone())
            });

        match app.get_component_ref::<RouterLayers>() {
            Some(layers) => {
                let mut layers: RouterLayers = (*layers).clone();
                layers.push(layer_fn);
                app.add_component(layers);
            }
            None => {
                let mut layers = RouterLayers::default();
                layers.push(layer_fn);
                app.add_component(layers);
            }
        }
    }

    fn dependencies(&self) -> Vec<&str> {
{% if authentication == 'jwt' %}
        vec![
            std::any::type_name::<WebPlugin>(),
            std::any::type_name::<crate::services::auth_plugin::AuthPlugin>(),
        ]
{% else %}
        vec![std::any::type_name::<WebPlugin>()]
{% endif %}
    }
}
