/// Summer plugin for multi-tenant Row-Level Security.
///
/// Tenant resolution happens directly in the [`TenantId`] extractor on every
/// protected route – no additional middleware is needed.
pub struct TenantPlugin;

#[async_trait]
impl Plugin for TenantPlugin {
    async fn build(&self, _app: &mut AppBuilder) {
        // Tenant resolution is handled directly in the TenantId extractor.
        // No middleware registration is required.
    }

    fn dependencies(&self) -> Vec<&str> {
{% if authentication == 'jwt' %}
        vec![
            std::any::type_name::<WebPlugin>(),
            std::any::type_name::<crate::services::auth_plugin::AuthPlugin>(),
        ]
{% else %}
        vec![std::any::type_name::<WebPlugin>()]
{% endif %}
    }
}
