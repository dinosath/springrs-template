/// ActivityPub JSON-LD representation of a {{ model }}.
///
/// Modelled after the `Note` / `Object` patterns in `activitypub-federation-rust`.
/// The struct is serialised with `camelCase` field names as required by the AP spec.
/// Entity-specific attributes are serialised via a flattened properties map,
/// keeping the struct generic and avoiding import issues with domain-specific types.
#[derive(Clone, Debug, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct Apub{{ model }} {
    #[serde(rename = "@context")]
    pub context: Value,
    /// Globally unique AP identifier (URL).
    pub id: String,
    #[serde(rename = "type")]
    pub kind: String,
    /// Human-readable name / title.
    pub name: String,
    /// The actor (server actor) that created this object.
    pub attributed_to: String,
    /// ISO 8601 publication timestamp.
    pub published: String,
    /// ISO 8601 last-update timestamp.
    pub updated: String,
    /// Canonical URL for this object.
    pub url: String,
    /// Entity-specific attributes from the database model.
    #[serde(flatten)]
    pub properties: serde_json::Map<String, Value>,
}

// ─── DB wrapper (mirrors activitypub-federation-rust's Db* pattern) ───────────

/// Database-backed {{ model }} with a resolved ActivityPub identifier URL.
///
/// Wraps the SeaORM [`Model`] and pre-computes the `ap_id` URL so that
/// conversion is infallible.
pub struct Db{{ model }} {
    pub model: Model,
    pub ap_id: Url,
}

impl Db{{ model }} {
    /// Wrap a SeaORM model with its computed AP identifier.
    pub fn from_model(model: Model, base_url: &str) -> Self {
        let ap_id = Url::parse(&format!("{}/ap/{{ plural }}/{}", base_url, model.id))
            .expect("valid AP URL");
        Self { model, ap_id }
    }

    /// Convert to the AP JSON-LD representation (mirrors `Object::into_json`).
    pub fn into_json(self, base_url: &str) -> Apub{{ model }} {
        let actor_url = format!("{}/ap/actor", base_url);

        // Serialize entity-specific attributes into a properties map.
        let mut properties = serde_json::Map::new();
        {% for name, property in entity.attributes | items -%}
        {%- if property.type != 'relation' and not property.writeOnly and name | snake_case not in ap_reserved -%}
        {% if not property.required -%}
        if let Some(ref val) = self.model.{{ name | snake_case }} {
            properties.insert("{{ name | snake_case }}".to_string(), json!(val));
        }
        {% else -%}
        properties.insert("{{ name | snake_case }}".to_string(), json!(self.model.{{ name | snake_case }}));
        {% endif -%}
        {%- endif -%}
        {% endfor %}

        Apub{{ model }} {
            context: json!(AP_CONTEXT),
            id: self.ap_id.to_string(),
            kind: "Object".to_string(),
            {% if 'name' in entity.attributes -%}
            name: {% if entity.attributes.name.required | default(false) %}self.model.name.clone(){% else %}self.model.name.clone().unwrap_or_else(|| format!("{{ model }} #{}", self.model.id)){% endif %},
            {% else -%}
            name: format!("{{ model }} #{}", self.model.id),
            {% endif -%}
            attributed_to: actor_url,
            published: self.model.created_at.format("%Y-%m-%dT%H:%M:%SZ").to_string(),
            updated: self.model.last_updated.format("%Y-%m-%dT%H:%M:%SZ").to_string(),
            url: self.ap_id.to_string(),
            properties,
        }
    }
}

// ─── Activity types (mirrors activitypub-federation-rust Activity pattern) ────

/// A `Create` activity wrapping an [`Apub{{ model }}`].
#[derive(Debug, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct Create{{ model }}Activity {
    #[serde(rename = "@context")]
    pub context: Value,
    #[serde(rename = "type")]
    pub kind: String,
    pub id: String,
    pub actor: String,
    pub object: Apub{{ model }},
    pub published: String,
}

impl Create{{ model }}Activity {
    /// Wrap an AP object in a `Create` activity, following the same pattern as
    /// `activitypub-federation-rust`'s `CreatePost` activity.
    pub fn new(object: Apub{{ model }}, base_url: &str) -> Self {
        let activity_id = format!(
            "{}/ap/activities/create-{{ entity_snake }}-{}",
            base_url,
            Utc::now().timestamp_millis()
        );
        Self {
            context: json!(AP_CONTEXT),
            kind: "Create".to_string(),
            id: activity_id,
            actor: object.attributed_to.clone(),
            object,
            published: Utc::now().format("%Y-%m-%dT%H:%M:%SZ").to_string(),
        }
    }
}

