/// GET /ap/{{ plural }}/:id — Retrieve the ActivityPub Object representation.
#[get("/ap/{{ plural }}/{id}")]
pub async fn get_object(
    Component(db): Component<DbConn>,
    Path(id): Path<i32>,
) -> Result<impl IntoResponse> {
    debug!("AP: Fetching {{ entity_snake }} object with id: {}", id);
    let model = Entity::find_by_id(id)
        .one(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| summer_web::error::KnownWebError::not_found("not found"))?;

    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let db_obj = Db{{ model }}::from_model(model, &base_url);
    let ap_obj = db_obj.into_json(&base_url);

    Ok((StatusCode::OK, ap_headers(), Json(ap_obj)))
}

/// GET /ap/{{ plural }} — OrderedCollection of all {{ plural }}.
#[get("/ap/{{ plural }}")]
pub async fn list_collection(
    Component(db): Component<DbConn>,
) -> Result<impl IntoResponse> {
    debug!("AP: Fetching {{ plural }} collection");
    let models = Entity::find()
        .all(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?;

    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let items: Vec<Apub{{ model }}> = models
        .into_iter()
        .map(|m| Db{{ model }}::from_model(m, &base_url).into_json(&base_url))
        .collect();

    let body = json!({
        "@context": AP_CONTEXT,
        "id": format!("{}/ap/{{ plural }}", base_url),
        "type": "OrderedCollection",
        "totalItems": items.len(),
        "orderedItems": items,
    });

    Ok((StatusCode::OK, ap_headers(), Json(body)))
}

/// GET /ap/{{ plural }}/:id/outbox — Outbox (activity history) for a {{ model }}.
///
/// Returns an `OrderedCollection` containing a `Create` activity, following the
/// same pattern as `activitypub-federation-rust`'s activity wrapping.
#[get("/ap/{{ plural }}/{id}/outbox")]
pub async fn outbox(
    Component(db): Component<DbConn>,
    Path(id): Path<i32>,
) -> Result<impl IntoResponse> {
    debug!("AP: Fetching outbox for {{ entity_snake }} with id: {}", id);
    let model = Entity::find_by_id(id)
        .one(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| summer_web::error::KnownWebError::not_found("not found"))?;

    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let db_obj = Db{{ model }}::from_model(model, &base_url);
    let ap_obj = db_obj.into_json(&base_url);
    let activity = Create{{ model }}Activity::new(ap_obj, &base_url);

    let body = json!({
        "@context": AP_CONTEXT,
        "id": format!("{}/ap/{{ plural }}/{}/outbox", base_url, id),
        "type": "OrderedCollection",
        "totalItems": 1,
        "orderedItems": [activity],
    });

    Ok((StatusCode::OK, ap_headers(), Json(body)))
}

/// POST /ap/{{ plural }}/:id/inbox — Receive an ActivityPub activity.
///
/// Following `activitypub-federation-rust`'s inbox pattern:
/// 1. Verify the target entity exists.
/// 2. Parse the activity type.
/// 3. Dispatch to the appropriate handler.
///
/// In a full implementation, HTTP signatures would be verified using the
/// sender's public key before processing.
#[post("/ap/{{ plural }}/{id}/inbox")]
pub async fn inbox(
    Component(db): Component<DbConn>,
    Path(id): Path<i32>,
    Json(activity): Json<Value>,
) -> Result<impl IntoResponse> {
    let activity_type = activity
        .get("type")
        .and_then(|v| v.as_str())
        .unwrap_or("Unknown");
    let actor = activity
        .get("actor")
        .and_then(|v| v.as_str())
        .unwrap_or("unknown");

    debug!(
        "AP: Received {} from {} in inbox for {{ entity_snake }} {}",
        activity_type, actor, id
    );

    // Verify the target entity exists.
    let _model = Entity::find_by_id(id)
        .one(&db)
        .await
        .map_err(|e| summer_web::error::KnownWebError::internal_server_error(e.to_string()))?
        .ok_or_else(|| summer_web::error::KnownWebError::not_found("not found"))?;

    // TODO: Verify HTTP signature against sender's public key using
    // activitypub_federation::protocol::verification helpers.

    match activity_type {
        "Create" => {
            debug!("AP: Processing Create activity for {{ entity_snake }} {}", id);
        }
        "Update" => {
            debug!("AP: Processing Update activity for {{ entity_snake }} {}", id);
        }
        "Delete" => {
            debug!("AP: Processing Delete activity for {{ entity_snake }} {}", id);
        }
        "Follow" => {
            debug!("AP: Processing Follow activity for {{ entity_snake }} {}", id);
        }
        "Accept" => {
            debug!("AP: Processing Accept activity for {{ entity_snake }} {}", id);
        }
        other => {
            debug!("AP: Ignoring unhandled activity type '{}' for {{ entity_snake }} {}", other, id);
        }
    }

    Ok(StatusCode::ACCEPTED)
}

