//! Server-level ActivityPub actor and WebFinger discovery.
//!
//! Follows the patterns from [`activitypub-federation-rust`]:
//! - The server actor is an ActivityPub `Application` with an HTTP-signature keypair.
//! - WebFinger resolves `acct:` URIs to the server actor.
//! - The inbox accepts incoming federated activities.

use summer_web::{get, post};
use summer_web::{
    error::Result,
    extractor::Query,
    axum::{
        http::{HeaderMap, HeaderValue, StatusCode},
        response::IntoResponse,
    },
};
use summer::tracing::debug;
use serde::{Deserialize, Serialize};
use serde_json::{json, Value};
use url::Url;

use crate::services::federation_plugin::{federation_config, server_keypair};

/// ActivityPub JSON-LD contexts.
const AP_CONTEXT: &str = "https://www.w3.org/ns/activitystreams";
const SECURITY_CONTEXT: &str = "https://w3id.org/security/v1";
const AP_CONTENT_TYPE: &str = "application/activity+json";
const WEBFINGER_CONTENT_TYPE: &str = "application/jrd+json";

fn ap_headers() -> HeaderMap {
    let mut headers = HeaderMap::new();
    headers.insert("Content-Type", HeaderValue::from_static(AP_CONTENT_TYPE));
    headers
}

// ─── WebFinger (RFC 7033) ─────────────────────────────────────────────────────

#[derive(Debug, Deserialize)]
pub struct WebFingerQuery {
    pub resource: String,
}

/// WebFinger response following RFC 7033.
#[derive(Debug, Serialize)]
pub struct WebFingerResponse {
    pub subject: String,
    pub aliases: Vec<String>,
    pub links: Vec<WebFingerLink>,
}

#[derive(Debug, Serialize)]
pub struct WebFingerLink {
    pub rel: String,
    #[serde(rename = "type")]
    pub kind: String,
    pub href: String,
}

/// GET /.well-known/webfinger — WebFinger discovery endpoint.
///
/// Resolves `acct:preferred_username@domain` to the server-level AP actor,
/// following the same pattern as Lemmy / Mastodon.
#[get("/.well-known/webfinger")]
pub async fn webfinger(Query(params): Query<WebFingerQuery>) -> Result<impl IntoResponse> {
    debug!("WebFinger request for resource: {}", params.resource);

    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);

    // Extract the name portion from "acct:name@domain" if provided.
    let _name = params
        .resource
        .strip_prefix("acct:")
        .and_then(|r| r.split('@').next())
        .unwrap_or("{{ project_name | snake_case }}");

    let actor_url = format!("{}/ap/actor", base_url);

    let response = WebFingerResponse {
        subject: params.resource.clone(),
        aliases: vec![actor_url.clone()],
        links: vec![WebFingerLink {
            rel: "self".to_string(),
            kind: AP_CONTENT_TYPE.to_string(),
            href: actor_url,
        }],
    };

    let mut headers = HeaderMap::new();
    headers.insert("Content-Type", HeaderValue::from_static(WEBFINGER_CONTENT_TYPE));
    Ok((StatusCode::OK, headers, summer_web::extractor::Json(response)))
}

// ─── Server-level actor ───────────────────────────────────────────────────────

/// ActivityPub `Application` actor representation for the server.
///
/// Modelled after the `Person` type in `activitypub-federation-rust`,
/// but using `Application` kind since this represents the service itself.
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct ServerActor {
    #[serde(rename = "@context")]
    pub context: Value,
    pub id: String,
    #[serde(rename = "type")]
    pub kind: String,
    pub name: String,
    pub preferred_username: String,
    pub inbox: String,
    pub outbox: String,
    pub followers: String,
    pub following: String,
    pub url: String,
    pub public_key: ActorPublicKey,
}

/// Public key block following the W3C Security Vocabulary, used for
/// HTTP Signature verification (same structure as Lemmy/Mastodon).
#[derive(Debug, Clone, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct ActorPublicKey {
    pub id: String,
    pub owner: String,
    pub public_key_pem: String,
}

/// GET /ap/actor — Server-level ActivityPub actor (Application type).
///
/// Returns a full actor document with a public key so that remote servers
/// can verify HTTP signatures on activities sent by this instance.
#[get("/ap/actor")]
pub async fn actor() -> Result<impl IntoResponse> {
    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);
    let actor_id = format!("{}/ap/actor", base_url);
    let kp = server_keypair();

    let actor = ServerActor {
        context: json!([AP_CONTEXT, SECURITY_CONTEXT]),
        id: actor_id.clone(),
        kind: "Application".to_string(),
        name: "{{ project_name }}".to_string(),
        preferred_username: "{{ project_name | snake_case }}".to_string(),
        inbox: format!("{}/inbox", actor_id),
        outbox: format!("{}/outbox", actor_id),
        followers: format!("{}/followers", actor_id),
        following: format!("{}/following", actor_id),
        url: base_url,
        public_key: ActorPublicKey {
            id: format!("{}#main-key", actor_id),
            owner: actor_id,
            public_key_pem: kp.public_key.clone(),
        },
    };

    Ok((StatusCode::OK, ap_headers(), summer_web::extractor::Json(actor)))
}

/// POST /ap/actor/inbox — Server-level inbox for receiving federated activities.
///
/// Accepts incoming activities and dispatches based on `type` field.
/// In a full implementation, this would verify HTTP signatures using
/// `activitypub_federation::protocol::verification` helpers and then
/// dispatch to the appropriate `Activity::receive()` handler.
#[post("/ap/actor/inbox")]
pub async fn server_inbox(
    summer_web::extractor::Json(activity): summer_web::extractor::Json<Value>,
) -> Result<impl IntoResponse> {
    let activity_type = activity
        .get("type")
        .and_then(|v| v.as_str())
        .unwrap_or("Unknown");
    let sender = activity
        .get("actor")
        .and_then(|v| v.as_str())
        .unwrap_or("unknown");

    debug!("AP: Server inbox received {} from {}", activity_type, sender);

    // TODO: Verify HTTP signature against sender's public key.
    // TODO: Dispatch to Activity::receive() implementations.

    Ok(StatusCode::ACCEPTED)
}

/// GET /ap/actor/outbox — Server-level outbox (OrderedCollection).
#[get("/ap/actor/outbox")]
pub async fn server_outbox() -> Result<impl IntoResponse> {
    let domain = federation_config().domain();
    let base_url = format!("https://{}", domain);

    let outbox = json!({
        "@context": AP_CONTEXT,
        "id": format!("{}/ap/actor/outbox", base_url),
        "type": "OrderedCollection",
        "totalItems": 0,
        "orderedItems": [],
    });

    Ok((StatusCode::OK, ap_headers(), summer_web::extractor::Json(outbox)))
}

